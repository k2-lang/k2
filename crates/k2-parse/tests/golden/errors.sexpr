  (test "\"valid input is parsed and doubled\""
    (block
      (const alloc
        (field allocator
          (field testing
            (ident std)
          )
        )
      )
      (const cell
        (unary try
          (call
            (ident parseDoubled)
            (ident alloc)
            (str "\"21\"")
          )
        )
      )
      (defer
        (expr
          (call
            (field destroy
              (ident alloc)
            )
            (ident cell)
          )
        )
      )
      (expr
        (unary try
          (call
            (field expectEqual
              (field testing
                (ident std)
              )
            )
            (builtin @as
              (ident u32)
              (int 42)
            )
            (deref
              (ident cell)
            )
          )
        )
      )
    )
  )
  (test "\"empty input returns ParseError.Empty and leaks nothing\""
    (block
      (const alloc
        (field allocator
          (field testing
            (ident std)
          )
        )
      )
      (expr
        (unary try
          (call
            (field expectError
              (field testing
                (ident std)
              )
            )
            (field Empty
              (ident ParseError)
            )
            (call
              (ident parseDoubled)
              (ident alloc)
              (str "\"\"")
            )
          )
        )
      )
    )
  )
  (test "\"a non-digit triggers errdefer cleanup, so no leak\""
    (block
      (const alloc
        (field allocator
          (field testing
            (ident std)
          )
        )
      )
      (expr
        (unary try
          (call
            (field expectError
              (field testing
                (ident std)
              )
            )
            (field NotANumber
              (ident ParseError)
            )
            (call
              (ident parseDoubled)
              (ident alloc)
              (str "\"12x\"")
            )
          )
        )
      )
    )
  )
  (test "\"exit codes are exhaustive over ParseError\""
    (block
      (expr
        (unary try
          (call
            (field expectEqual
              (field testing
                (ident std)
              )
            )
            (builtin @as
              (ident u8)
              (int 10)
            )
            (call
              (ident exitCodeFor)
              (error-lit Empty)
            )
          )
        )
      )
      (expr
        (unary try
          (call
            (field expectEqual
              (field testing
                (ident std)
              )
            )
            (builtin @as
              (ident u8)
              (int 11)
            )
            (call
              (ident exitCodeFor)
              (error-lit NotANumber)
            )
          )
        )
      )
      (expr
        (unary try
          (call
            (field expectEqual
              (field testing
                (ident std)
              )
            )
            (builtin @as
              (ident u8)
              (int 12)
            )
            (call
              (ident exitCodeFor)
              (error-lit Overflow)
            )
          )
        )
      )
    )
  )
  (test "\"parseU32 succeeds, and catch supplies a default on failure\""
    (block
      (expr
        (unary try
          (call
            (field expectEqual
              (field testing
                (ident std)
              )
            )
            (builtin @as
              (ident u32)
              (int 123)
            )
            (unary try
              (call
                (ident parseU32)
                (str "\"123\"")
              )
            )
          )
        )
      )
      (expr
        (unary try
          (call
            (field expectEqual
              (field testing
                (ident std)
              )
            )
            (builtin @as
              (ident u32)
              (int 0)
