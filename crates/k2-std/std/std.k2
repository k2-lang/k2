// std.k2 — the bundled k2 standard library, written in k2.
//
// k2 — "Kardashev Type II": total control over the machine, with zero waste.
//
// This file is the BODY of the `std` namespace: the driver wraps it in a single
// synthetic `const std = struct { <this file> };` and prepends it into the
// user's source, so `@import("std")` resolves to a REAL compiled module. Every
// declaration here is parsed, name-resolved, type-checked, monomorphized,
// lowered, and executed exactly like user code.
//
// The design honors the charter pillar **No hidden allocation**: nothing here
// allocates without an explicit `Allocator` capability, and the allocator is
// HANDLE-BASED — an `Allocator` is a `u32` id that selects an allocator
// instance in the VM, so different kinds (GPA, arena, fixed-buffer) behave
// differently with no fn-pointer vtables. The handle methods bottom out in a
// few `@builtin` leaf intrinsics (`@allocRaw`/`@reallocRaw`/`@freeRaw`/…) that
// the VM implements over its managed heap.

// =========================================================================
//  mem — the Allocator capability + small memory helpers
// =========================================================================

/// The bundled-std view of memory utilities. The `Allocator` *type* itself is
/// the predeclared opaque capability (so a user signature `fn f(a: Allocator)`
/// and `std`'s own uses name the SAME type); `mem` adds value-level helpers.
pub const mem = struct {
    /// Copy `src` into `dst` element-by-element (both must be at least `n` long).
    pub fn copy(comptime T: type, dst: []T, src: []const T) void {
        var i: usize = 0;
        while (i < src.len) : (i += 1) {
            dst[i] = src[i];
        }
    }

    /// `true` if two slices have equal length and equal elements.
    pub fn eql(comptime T: type, a: []const T, b: []const T) bool {
        if (a.len != b.len) return false;
        var i: usize = 0;
        while (i < a.len) : (i += 1) {
            if (a[i] != b[i]) return false;
        }
        return true;
    }

    /// Set every element of `slice` to `value`.
    pub fn fill(comptime T: type, slice: []T, value: T) void {
        var i: usize = 0;
        while (i < slice.len) : (i += 1) slice[i] = value;
    }

    /// Reverse `slice` in place.
    pub fn reverse(comptime T: type, slice: []T) void {
        if (slice.len == 0) return;
        var i: usize = 0;
        var j: usize = slice.len - 1;
        while (i < j) {
            const t = slice[i];
            slice[i] = slice[j];
            slice[j] = t;
            i += 1;
            j -= 1;
        }
    }

    /// Swap the elements at indices `i` and `j` (must both be in bounds).
    pub fn swap(comptime T: type, slice: []T, i: usize, j: usize) void {
        const t = slice[i];
        slice[i] = slice[j];
        slice[j] = t;
    }

    /// The index of the first element equal to `needle`, or `null`.
    pub fn indexOfScalar(comptime T: type, slice: []const T, needle: T) ?usize {
        var i: usize = 0;
        while (i < slice.len) : (i += 1) {
            if (slice[i] == needle) return i;
        }
        return null;
    }

    /// The index of the LAST element equal to `needle`, or `null`.
    pub fn lastIndexOfScalar(comptime T: type, slice: []const T, needle: T) ?usize {
        var i: usize = slice.len;
        while (i > 0) {
            i -= 1;
            if (slice[i] == needle) return i;
        }
        return null;
    }

    /// `true` if `slice` contains an element equal to `needle`.
    pub fn contains(comptime T: type, slice: []const T, needle: T) bool {
        return indexOfScalar(T, slice, needle) != null;
    }

    /// The number of elements of `slice` equal to `needle`.
    pub fn count(comptime T: type, slice: []const T, needle: T) usize {
        var n: usize = 0;
        var i: usize = 0;
        while (i < slice.len) : (i += 1) {
            if (slice[i] == needle) n += 1;
        }
        return n;
    }

    /// The number of leading elements for which `a` and `b` agree (the common
    /// prefix length). Stops at the shorter length.
    pub fn commonPrefixLen(comptime T: type, a: []const T, b: []const T) usize {
        const n = if (a.len < b.len) a.len else b.len;
        var i: usize = 0;
        while (i < n) : (i += 1) {
            if (a[i] != b[i]) return i;
        }
        return n;
    }

    /// `true` if `slice` begins with `prefix` (element-wise).
    pub fn startsWith(comptime T: type, slice: []const T, prefix: []const T) bool {
        if (prefix.len > slice.len) return false;
        var i: usize = 0;
        while (i < prefix.len) : (i += 1) {
            if (slice[i] != prefix[i]) return false;
        }
        return true;
    }

    /// `true` if `slice` ends with `suffix` (element-wise).
    pub fn endsWith(comptime T: type, slice: []const T, suffix: []const T) bool {
        if (suffix.len > slice.len) return false;
        const off = slice.len - suffix.len;
        var i: usize = 0;
        while (i < suffix.len) : (i += 1) {
            if (slice[off + i] != suffix[i]) return false;
        }
        return true;
    }

    /// The index of the first occurrence of the sub-slice `needle` in `haystack`,
    /// or `null`. An empty needle matches at 0. Naive O(n*m) scan.
    pub fn indexOf(comptime T: type, haystack: []const T, needle: []const T) ?usize {
        if (needle.len == 0) return 0;
        if (needle.len > haystack.len) return null;
        const last = haystack.len - needle.len;
        var i: usize = 0;
        while (i <= last) : (i += 1) {
            var j: usize = 0;
            while (j < needle.len and haystack[i + j] == needle[j]) j += 1;
            if (j == needle.len) return i;
        }
        return null;
    }

    /// `true` if `min <= x <= max` for the slice's elements all within `[lo, hi]`.
    /// (Convenience: every element in range.)
    pub fn allInRange(comptime T: type, slice: []const T, lo: T, hi: T) bool {
        var i: usize = 0;
        while (i < slice.len) : (i += 1) {
            if (slice[i] < lo or slice[i] > hi) return false;
        }
        return true;
    }
};

// =========================================================================
//  str — byte-string (`[]const u8`) search and trimming
// =========================================================================

/// Pure, allocation-free operations over byte strings. Search returns scalar
/// byte indices; trimming returns sub-slices (no copy). These build on `mem`
/// but specialize to `u8` for the common text-processing path.
pub const str = struct {
    /// `true` if `a` and `b` are byte-for-byte equal.
    pub fn equal(a: []const u8, b: []const u8) bool {
        return mem.eql(u8, a, b);
    }

    /// `true` if `s` begins with `prefix`.
    pub fn startsWith(s: []const u8, prefix: []const u8) bool {
        if (prefix.len > s.len) return false;
        var i: usize = 0;
        while (i < prefix.len) : (i += 1) {
            if (s[i] != prefix[i]) return false;
        }
        return true;
    }

    /// `true` if `s` ends with `suffix`.
    pub fn endsWith(s: []const u8, suffix: []const u8) bool {
        if (suffix.len > s.len) return false;
        const off = s.len - suffix.len;
        var i: usize = 0;
        while (i < suffix.len) : (i += 1) {
            if (s[off + i] != suffix[i]) return false;
        }
        return true;
    }

    /// The index of the first occurrence of `needle` in `haystack`, or `null`. An
    /// empty needle matches at 0. Naive O(n*m) scan (fine for short patterns).
    pub fn indexOf(haystack: []const u8, needle: []const u8) ?usize {
        if (needle.len == 0) return 0;
        if (needle.len > haystack.len) return null;
        const last = haystack.len - needle.len;
        var i: usize = 0;
        while (i <= last) : (i += 1) {
            var j: usize = 0;
            while (j < needle.len and haystack[i + j] == needle[j]) j += 1;
            if (j == needle.len) return i;
        }
        return null;
    }

    /// `true` if `needle` occurs anywhere in `haystack`.
    pub fn contains(haystack: []const u8, needle: []const u8) bool {
        return indexOf(haystack, needle) != null;
    }

    /// The number of NON-overlapping occurrences of `needle` in `haystack`.
    pub fn countSubstr(haystack: []const u8, needle: []const u8) usize {
        if (needle.len == 0) return 0;
        var n: usize = 0;
        var i: usize = 0;
        while (i + needle.len <= haystack.len) {
            var j: usize = 0;
            while (j < needle.len and haystack[i + j] == needle[j]) j += 1;
            if (j == needle.len) {
                n += 1;
                i += needle.len;
            } else {
                i += 1;
            }
        }
        return n;
    }

    /// `s` with leading ASCII whitespace removed (a sub-slice, no copy).
    pub fn trimLeft(s: []const u8) []const u8 {
        var i: usize = 0;
        while (i < s.len and ascii.isWhitespace(s[i])) i += 1;
        return s[i..s.len];
    }

    /// `s` with trailing ASCII whitespace removed (a sub-slice, no copy).
    pub fn trimRight(s: []const u8) []const u8 {
        var j: usize = s.len;
        while (j > 0 and ascii.isWhitespace(s[j - 1])) j -= 1;
        return s[0..j];
    }

    /// `s` with both leading and trailing ASCII whitespace removed.
    pub fn trim(s: []const u8) []const u8 {
        return trimRight(trimLeft(s));
    }

    /// Lexicographic byte comparison: `< 0` if `a < b`, `0` if equal, `> 0` if
    /// `a > b`. A shorter prefix sorts before its extension.
    pub fn compare(a: []const u8, b: []const u8) i32 {
        const n = if (a.len < b.len) a.len else b.len;
        var i: usize = 0;
        while (i < n) : (i += 1) {
            if (a[i] < b[i]) return -1;
            if (a[i] > b[i]) return 1;
        }
        if (a.len < b.len) return -1;
        if (a.len > b.len) return 1;
        return 0;
    }

    /// `true` if `a` sorts strictly before `b` lexicographically.
    pub fn lessThan(a: []const u8, b: []const u8) bool {
        return compare(a, b) < 0;
    }

    /// `true` if `a` and `b` are equal ignoring ASCII letter case.
    pub fn eqlIgnoreCase(a: []const u8, b: []const u8) bool {
        if (a.len != b.len) return false;
        var i: usize = 0;
        while (i < a.len) : (i += 1) {
            if (ascii.toLower(a[i]) != ascii.toLower(b[i])) return false;
        }
        return true;
    }

    /// `true` if `s` contains the single byte `c`.
    pub fn containsScalar(s: []const u8, c: u8) bool {
        return mem.indexOfScalar(u8, s, c) != null;
    }

    /// Count the non-overlapping fields of `s` split on the single byte `sep`
    /// (`"a,,b"` split on `,` is 3 fields). An empty string is one field.
    pub fn countSplit(s: []const u8, sep: u8) usize {
        var n: usize = 1;
        var i: usize = 0;
        while (i < s.len) : (i += 1) {
            if (s[i] == sep) n += 1;
        }
        return n;
    }

    /// A forward iterator over the `sep`-separated fields of a string. Each `next`
    /// returns the next field as a SUB-SLICE of the original (no copy, no
    /// allocation); the count matches `countSplit`. Drained when `next` returns
    /// `null`.
    pub const SplitIterator = struct {
        s: []const u8,
        sep: u8,
        pos: usize,
        done: bool,

        /// The next field, or `null` once every field has been yielded.
        pub fn next(self: *@This()) ?[]const u8 {
            if (self.done) return null;
            const start = self.pos;
            var i = self.pos;
            while (i < self.s.len and self.s[i] != self.sep) i += 1;
            const field = self.s[start..i];
            if (i < self.s.len) {
                self.pos = i + 1;
            } else {
                self.done = true;
            }
            return field;
        }
    };

    /// A `SplitIterator` over `s` divided on the single byte `sep`. `"a,b,c"` split
    /// on `,` yields `"a"`, `"b"`, `"c"`; a trailing/leading `sep` yields an empty
    /// field, exactly as `countSplit` counts.
    pub fn splitScalar(s: []const u8, sep: u8) SplitIterator {
        return SplitIterator{ .s = s, .sep = sep, .pos = 0, .done = false };
    }

    /// Concatenate `parts` with `sep` between them into a freshly allocated buffer
    /// (the caller owns and frees it). `join(a, &.{}, sep)` is an empty string.
    pub fn join(alloc: Allocator, parts: []const []const u8, sep: []const u8) ![]u8 {
        var total: usize = 0;
        var i: usize = 0;
        while (i < parts.len) : (i += 1) total += parts[i].len;
        if (parts.len > 1) total += sep.len * (parts.len - 1);
        const out = try alloc.alloc(u8, total);
        var pos: usize = 0;
        i = 0;
        while (i < parts.len) : (i += 1) {
            if (i > 0) {
                mem.copy(u8, out[pos .. pos + sep.len], sep);
                pos += sep.len;
            }
            mem.copy(u8, out[pos .. pos + parts[i].len], parts[i]);
            pos += parts[i].len;
        }
        return out;
    }

    /// Copy `s` into `dst` (at least `s.len` long), lowercasing ASCII letters, and
    /// return the written sub-slice.
    pub fn toLowerInto(dst: []u8, s: []const u8) []u8 {
        var i: usize = 0;
        while (i < s.len) : (i += 1) dst[i] = ascii.toLower(s[i]);
        return dst[0..s.len];
    }

    /// Copy `s` into `dst` (at least `s.len` long), uppercasing ASCII letters, and
    /// return the written sub-slice.
    pub fn toUpperInto(dst: []u8, s: []const u8) []u8 {
        var i: usize = 0;
        while (i < s.len) : (i += 1) dst[i] = ascii.toUpper(s[i]);
        return dst[0..s.len];
    }

    /// The index of the LAST occurrence of the sub-slice `needle` in `haystack`, or
    /// `null`. An empty needle matches at `haystack.len`.
    pub fn lastIndexOf(haystack: []const u8, needle: []const u8) ?usize {
        if (needle.len == 0) return haystack.len;
        if (needle.len > haystack.len) return null;
        var i: usize = haystack.len - needle.len + 1;
        while (i > 0) {
            i -= 1;
            var j: usize = 0;
            while (j < needle.len and haystack[i + j] == needle[j]) j += 1;
            if (j == needle.len) return i;
        }
        return null;
    }

    /// The index of the first occurrence of `needle` in `haystack` at or after
    /// `start`, or `null`.
    pub fn indexOfPos(haystack: []const u8, needle: []const u8, start: usize) ?usize {
        if (start > haystack.len) return null;
        const rel = indexOf(haystack[start..haystack.len], needle);
        if (rel == null) return null;
        return start + rel.?;
    }
};

// =========================================================================
//  hex — hexadecimal encode / decode (no allocation; caller supplies buffers)
// =========================================================================

/// Lowercase hexadecimal codecs over caller-provided buffers — no allocation.
/// Encoding needs `2 * src.len` output bytes; decoding needs `src.len / 2`.
pub const hex = struct {
    const digits = "0123456789abcdef";

    /// Writes the lowercase hex of `src` into `dst` (which must be at least
    /// `2 * src.len` long) and returns the written sub-slice.
    pub fn encode(dst: []u8, src: []const u8) []u8 {
        var i: usize = 0;
        while (i < src.len) : (i += 1) {
            const b = src[i];
            dst[i * 2] = digits[@as(usize, b >> 4)];
            dst[i * 2 + 1] = digits[@as(usize, b & 0x0F)];
        }
        return dst[0 .. src.len * 2];
    }

    /// The value `0..=15` of a single hex digit, or `null` if `c` is not one.
    pub fn nibble(c: u8) ?u8 {
        if (c >= '0' and c <= '9') return c - '0';
        if (c >= 'a' and c <= 'f') return c - 'a' + 10;
        if (c >= 'A' and c <= 'F') return c - 'A' + 10;
        return null;
    }

    /// Decodes hex `src` (even length, valid digits) into `dst` (at least
    /// `src.len / 2` long). Returns the number of bytes written, or `null` on an
    /// odd length or a non-hex digit.
    pub fn decode(dst: []u8, src: []const u8) ?usize {
        if (src.len % 2 != 0) return null;
        const n = src.len / 2;
        var i: usize = 0;
        while (i < n) : (i += 1) {
            const hi = nibble(src[i * 2]);
            const lo = nibble(src[i * 2 + 1]);
            if (hi == null or lo == null) return null;
            dst[i] = (hi.? << 4) | lo.?;
        }
        return n;
    }
};

// =========================================================================
//  base64 — standard RFC 4648 base64 (with `=` padding), caller buffers
// =========================================================================

/// Standard base64 (`A–Z a–z 0–9 + /`, `=`-padded), encoding/decoding through
/// caller-provided buffers — no allocation. `encodedLen`/`decodedLen` size the
/// output. Decoding rejects a wrong length or a non-alphabet byte with `null`.
pub const base64 = struct {
    const alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/";

    /// The exact encoded length for `n` input bytes: `4 * ceil(n / 3)`.
    pub fn encodedLen(n: usize) usize {
        return ((n + 2) / 3) * 4;
    }

    /// An upper bound on the decoded length for `n` base64 bytes: `3 * (n / 4)`.
    pub fn decodedLen(n: usize) usize {
        return (n / 4) * 3;
    }

    /// Encodes `src` into `dst` (at least `encodedLen(src.len)` long) and returns
    /// the written sub-slice. The final group is `=`-padded.
    pub fn encode(dst: []u8, src: []const u8) []u8 {
        var di: usize = 0;
        var si: usize = 0;
        // Whole 3-byte groups -> 4 chars.
        while (si + 3 <= src.len) {
            const n = (@as(u32, src[si]) << 16) | (@as(u32, src[si + 1]) << 8) | @as(u32, src[si + 2]);
            dst[di] = alphabet[@as(usize, (n >> 18) & 0x3F)];
            dst[di + 1] = alphabet[@as(usize, (n >> 12) & 0x3F)];
            dst[di + 2] = alphabet[@as(usize, (n >> 6) & 0x3F)];
            dst[di + 3] = alphabet[@as(usize, n & 0x3F)];
            si += 3;
            di += 4;
        }
        // A trailing 1- or 2-byte group, padded with `=`.
        const rem = src.len - si;
        if (rem == 1) {
            const n = @as(u32, src[si]) << 16;
            dst[di] = alphabet[@as(usize, (n >> 18) & 0x3F)];
            dst[di + 1] = alphabet[@as(usize, (n >> 12) & 0x3F)];
            dst[di + 2] = '=';
            dst[di + 3] = '=';
            di += 4;
        } else if (rem == 2) {
            const n = (@as(u32, src[si]) << 16) | (@as(u32, src[si + 1]) << 8);
            dst[di] = alphabet[@as(usize, (n >> 18) & 0x3F)];
            dst[di + 1] = alphabet[@as(usize, (n >> 12) & 0x3F)];
            dst[di + 2] = alphabet[@as(usize, (n >> 6) & 0x3F)];
            dst[di + 3] = '=';
            di += 4;
        }
        return dst[0..di];
    }

    /// The 0..=63 value of a base64 alphabet byte, or `null` (`=` is not a value).
    fn sextet(c: u8) ?u32 {
        if (c >= 'A' and c <= 'Z') return @as(u32, c - 'A');
        if (c >= 'a' and c <= 'z') return @as(u32, c - 'a' + 26);
        if (c >= '0' and c <= '9') return @as(u32, c - '0' + 52);
        if (c == '+') return 62;
        if (c == '/') return 63;
        return null;
    }

    /// Decodes base64 `src` (length a multiple of 4) into `dst`, returning the
    /// number of bytes written, or `null` on a bad length or non-alphabet byte.
    pub fn decode(dst: []u8, src: []const u8) ?usize {
        if (src.len % 4 != 0) return null;
        if (src.len == 0) return 0;
        var di: usize = 0;
        var si: usize = 0;
        while (si < src.len) {
            const c0 = sextet(src[si]);
            const c1 = sextet(src[si + 1]);
            if (c0 == null or c1 == null) return null;
            var n = (c0.? << 18) | (c1.? << 12);
            var out: usize = 1;
            // The third character: `=` ends the data after one output byte.
            if (src[si + 2] != '=') {
                const c2 = sextet(src[si + 2]);
                if (c2 == null) return null;
                n = n | (c2.? << 6);
                out = 2;
                if (src[si + 3] != '=') {
                    const c3 = sextet(src[si + 3]);
                    if (c3 == null) return null;
                    n = n | c3.?;
                    out = 3;
                }
            }
            dst[di] = @as(u8, @intCast((n >> 16) & 0xFF));
            if (out >= 2) dst[di + 1] = @as(u8, @intCast((n >> 8) & 0xFF));
            if (out >= 3) dst[di + 2] = @as(u8, @intCast(n & 0xFF));
            di += out;
            si += 4;
        }
        return di;
    }
};

// =========================================================================
//  hash — non-cryptographic checksums and digests (pure, no allocation)
// =========================================================================

/// Pure, allocation-free hashes and checksums over a byte slice. None is a
/// cryptographic hash. Each avoids a wrapping multiply (k2 has none) — FNV-1a is
/// masked to 32 bits each step, CRC-32 uses only XOR/shift, Adler-32 only add/mod.
pub const hash = struct {
    /// 32-bit FNV-1a. Masking to 32 bits each step keeps `h * prime` below 2^56, so
    /// the multiply never overflows a `u64`.
    pub fn fnv1a32(data: []const u8) u32 {
        var h: u64 = 2166136261;
        const prime: u64 = 16777619;
        const m: u64 = 0xFFFFFFFF;
        var i: usize = 0;
        while (i < data.len) : (i += 1) {
            h = h ^ @as(u64, data[i]);
            h = (h * prime) & m;
        }
        return @as(u32, @intCast(h));
    }

    /// CRC-32 (IEEE 802.3, reflected polynomial `0xEDB88320`), computed bit by bit
    /// — XOR and shifts only.
    pub fn crc32(data: []const u8) u32 {
        var crc: u32 = 0xFFFF_FFFF;
        var i: usize = 0;
        while (i < data.len) : (i += 1) {
            crc = crc ^ @as(u32, data[i]);
            var k: u32 = 0;
            while (k < 8) : (k += 1) {
                if (crc & 1 == 1) {
                    crc = (crc >> 1) ^ 0xEDB8_8320;
                } else {
                    crc = crc >> 1;
                }
            }
        }
        return crc ^ 0xFFFF_FFFF;
    }

    /// Adler-32 (RFC 1950): two rolling sums mod 65521, packed `(b << 16) | a`. Each
    /// running sum stays below the modulus, so add and `%` never overflow `u32`.
    pub fn adler32(data: []const u8) u32 {
        const md: u32 = 65521;
        var a: u32 = 1;
        var b: u32 = 0;
        var i: usize = 0;
        while (i < data.len) : (i += 1) {
            a = (a + @as(u32, data[i])) % md;
            b = (b + a) % md;
        }
        return (b << 16) | a;
    }
};

// =========================================================================
//  heap — the standard allocators
// =========================================================================

/// The family of standard allocators. They all expose the same `Allocator`
/// interface (the handle methods `alloc`/`free`/`realloc`/`create`/`destroy`),
/// so code written against `Allocator` works with any of them. You choose a
/// STRATEGY where you create the allocator; the rest of the program is agnostic.
pub const heap = struct {
    /// The general-purpose allocator: the default-quality allocator and a leak /
    /// double-free / use-after-free detector in safe builds. `deinit` reports
    /// whether anything leaked. In ReleaseFast the checks are stripped.
    pub const GeneralPurposeAllocator = struct {
        const Self = @This();
        /// The VM-side handle id of this allocator instance.
        id: u32,

        /// Create a fresh GPA. Takes `*System` to make heap authority explicit.
        pub fn init(sys: *System) Self {
            return Self{ .id = @allocId(1, 0) };
        }

        /// The `Allocator` capability backed by this GPA.
        pub fn allocator(self: *Self) Allocator {
            return @allocHandle(self.id);
        }

        /// Tear down the GPA, reporting whether any allocation was never freed.
        /// `true` means a leak — the canonical pattern is to `@panic` on it.
        pub fn deinit(self: *Self) bool {
            return @gpaDeinit(self.id);
        }
    };

    /// An arena allocator: allocates from a backing allocator and NEVER frees
    /// individual allocations — everything is freed at once on `deinit`. Ideal
    /// for phase- or request-scoped work where many objects share one lifetime.
    pub const ArenaAllocator = struct {
        const Self = @This();
        id: u32,
        backing: Allocator,

        /// Create an arena over a backing allocator.
        pub fn init(backing: Allocator) Self {
            return Self{ .backing = backing, .id = @allocId(2, 0) };
        }

        /// The `Allocator` capability backed by this arena.
        pub fn allocator(self: *Self) Allocator {
            return @allocHandle(self.id);
        }

        /// Free EVERYTHING the arena handed out, in one operation.
        pub fn deinit(self: *Self) void {
            @arenaDeinit(self.id);
        }
    };

    /// A fixed-buffer allocator: hands out memory from a caller-provided byte
    /// buffer, with zero heap involvement. Allocation fails with `OutOfMemory`
    /// when the buffer is exhausted. For real-time / embedded / bounded work.
    pub const FixedBufferAllocator = struct {
        const Self = @This();
        id: u32,

        /// Create an FBA over a caller buffer.
        pub fn init(buffer: []u8) Self {
            return Self{ .id = @allocId(3, 0, buffer) };
        }

        /// The `Allocator` capability backed by this buffer.
        pub fn allocator(self: *Self) Allocator {
            return @allocHandle(self.id);
        }
    };

    /// The page allocator: requests memory directly from the OS. Here it is the
    /// VM's managed heap proxy (the default allocator behavior). Use it as the
    /// backing allocator for an arena, or for a few large, long-lived buffers.
    pub const PageAllocator = struct {
        const Self = @This();
        id: u32,

        pub fn init(sys: *System) Self {
            return Self{ .id = @allocId(0, 0) };
        }

        pub fn allocator(self: *Self) Allocator {
            return @allocHandle(self.id);
        }
    };

    /// A bump / stack allocator: a linear-bump region over a caller buffer where
    /// `free` is a no-op and allocation fails with `OutOfMemory` once the buffer is
    /// exhausted. It is realized by the `FixedBufferAllocator` (the VM's kind-3
    /// bump allocator), so `StackAllocator` is a clarifying ALIAS — use it when the
    /// "bump cursor over a fixed region" intent is what you want to communicate.
    pub const StackAllocator = FixedBufferAllocator;

    /// An allocator WRAPPER that tallies allocation activity while forwarding every
    /// request to an inner `Allocator`. It exposes the same method surface
    /// (`alloc`/`free`/`realloc`/`create`/`destroy`) the `Allocator` capability
    /// does, so it is duck-typed-conformant: pass it to any container that takes
    /// its allocator by `anytype` (exactly how `ArrayList` uses its `alloc`). The
    /// counters (`n_alloc`/`n_free`/`bytes`) are live and queryable at any time —
    /// the canonical "how much did this phase allocate?" instrument. Because the
    /// `Allocator` handle is opaque, conformance is by method surface, not by
    /// producing a new handle the VM dispatches through.
    pub const CountingAllocator = struct {
        const Self = @This();
        /// The wrapped allocator every request forwards to.
        inner: Allocator,
        /// The number of successful `alloc`/`create`/`realloc` calls.
        n_alloc: usize,
        /// The number of `free`/`destroy` calls.
        n_free: usize,
        /// The total element count handed out across `alloc`/`realloc` (a cheap
        /// proxy for bytes when `T` is `u8`, and an element tally otherwise).
        bytes: usize,

        /// Wrap `inner`, with all counters at zero.
        pub fn init(inner: Allocator) Self {
            return Self{ .inner = inner, .n_alloc = 0, .n_free = 0, .bytes = 0 };
        }

        /// Allocate `n` elements of `T`, tallying one alloc and `n` units.
        pub fn alloc(self: *Self, comptime T: type, n: usize) ![]T {
            const s = try self.inner.alloc(T, n);
            self.n_alloc += 1;
            self.bytes += n;
            return s;
        }

        /// Grow/shrink `slice` to `n` elements, tallying it as one alloc of `n`.
        pub fn realloc(self: *Self, slice: anytype, n: usize) !@TypeOf(slice) {
            const s = try self.inner.realloc(slice, n);
            self.n_alloc += 1;
            self.bytes += n;
            return s;
        }

        /// Free `slice`, tallying one free.
        pub fn free(self: *Self, slice: anytype) void {
            self.n_free += 1;
            self.inner.free(slice);
        }

        /// Allocate a single `T`, tallying one alloc of one unit.
        pub fn create(self: *Self, comptime T: type) !*T {
            const p = try self.inner.create(T);
            self.n_alloc += 1;
            self.bytes += 1;
            return p;
        }

        /// Destroy a single-item pointer, tallying one free.
        pub fn destroy(self: *Self, ptr: anytype) void {
            self.n_free += 1;
            self.inner.destroy(ptr);
        }
    };
};

// =========================================================================
//  ArrayList — the canonical growable container
// =========================================================================

/// A growable array of `T`, allocator-taking with explicit `init`/`deinit`.
/// `ArrayList` is an ordinary function from a type to a type, evaluated at
/// comptime — there is no special generics syntax. It stores the allocator it
/// was handed and frees with THAT SAME allocator on `deinit`. No hidden
/// allocation: `append` may fail with `OutOfMemory`, surfaced via `try`.
pub fn ArrayList(comptime T: type) type {
    return struct {
        const Self = @This();

        /// The live elements: a view of `store` truncated to the logical count.
        /// Reading `list.items.len` / `list.items[i]` sees exactly the elements
        /// that were appended.
        items: []T,
        /// The full capacity-length backing storage. `store.len` is the physical
        /// capacity; `items` is always `store[0..count]`.
        store: []T,
        /// The allocator this list owns its storage through.
        alloc: Allocator,

        /// An empty list bound to `alloc`. `&.{}` is the canonical empty slice.
        pub fn init(alloc: Allocator) Self {
            return Self{ .items = &.{}, .store = &.{}, .alloc = alloc };
        }

        /// Release the backing storage with the list's own allocator.
        pub fn deinit(self: *Self) void {
            if (self.store.len != 0) {
                self.alloc.free(self.store);
            }
        }

        /// Append `value`, growing the backing storage if needed.
        pub fn append(self: *Self, value: T) !void {
            const n = self.items.len;
            try self.ensureCapacity(n + 1);
            // Grow the logical view by one (over `store`) and write the new tail.
            self.items = self.store[0 .. n + 1];
            self.items[n] = value;
        }

        /// Ensure the backing storage holds at least `need` elements, doubling
        /// (from a floor of 8) so amortized append is O(1).
        pub fn ensureCapacity(self: *Self, need: usize) !void {
            if (need <= self.store.len) return;
            var new_cap: usize = if (self.store.len == 0) 8 else self.store.len * 2;
            if (new_cap < need) new_cap = need;
            const count = self.items.len;
            // `realloc` preserves contents; it returns a `new_cap`-length slice.
            self.store = try self.alloc.realloc(self.store, new_cap);
            // Keep `items` at the logical length over the grown storage.
            self.items = self.store[0..count];
        }

        /// The number of live elements.
        pub fn len(self: *const Self) usize {
            return self.items.len;
        }

        /// Bounds-checked access; absence is an optional, never an accidental null.
        pub fn get(self: *const Self, index: usize) ?T {
            if (index >= self.items.len) return null;
            return self.items[index];
        }

        /// Overwrite the element at `index` (must be in bounds).
        pub fn set(self: *Self, index: usize, value: T) void {
            self.items[index] = value;
        }

        /// The last element, or `null` if empty.
        pub fn getLast(self: *const Self) ?T {
            if (self.items.len == 0) return null;
            return self.items[self.items.len - 1];
        }

        /// Remove and return the last element, or `null` if empty (O(1)).
        pub fn pop(self: *Self) ?T {
            const n = self.items.len;
            if (n == 0) return null;
            const v = self.items[n - 1];
            self.items = self.store[0 .. n - 1];
            return v;
        }

        /// Append every element of `slice`, growing once to fit.
        pub fn appendSlice(self: *Self, slice: []const T) !void {
            const n = self.items.len;
            try self.ensureCapacity(n + slice.len);
            self.items = self.store[0 .. n + slice.len];
            var i: usize = 0;
            while (i < slice.len) : (i += 1) self.items[n + i] = slice[i];
        }

        /// Insert `value` at `index` (`0..=len`), shifting later elements right by
        /// one. O(n) in the number of shifted elements.
        pub fn insert(self: *Self, index: usize, value: T) !void {
            const n = self.items.len;
            try self.ensureCapacity(n + 1);
            self.items = self.store[0 .. n + 1];
            var i: usize = n;
            while (i > index) : (i -= 1) self.items[i] = self.items[i - 1];
            self.items[index] = value;
        }

        /// Remove and return the element at `index`, shifting later elements left
        /// (order-preserving, O(n)). `null` if `index` is out of bounds.
        pub fn removeAt(self: *Self, index: usize) ?T {
            const n = self.items.len;
            if (index >= n) return null;
            const v = self.items[index];
            var i: usize = index;
            while (i + 1 < n) : (i += 1) self.items[i] = self.items[i + 1];
            self.items = self.store[0 .. n - 1];
            return v;
        }

        /// Remove the element at `index` by swapping the LAST element into its slot
        /// (O(1), does NOT preserve order). `null` if `index` is out of bounds.
        pub fn swapRemove(self: *Self, index: usize) ?T {
            const n = self.items.len;
            if (index >= n) return null;
            const v = self.items[index];
            self.items[index] = self.items[n - 1];
            self.items = self.store[0 .. n - 1];
            return v;
        }

        /// Drop all elements (capacity is retained; the storage is not freed).
        pub fn clear(self: *Self) void {
            self.items = self.store[0..0];
        }
    };
}

// =========================================================================
//  HashMap — the canonical unordered map (open addressing + tombstones)
// =========================================================================
//
// `HashMap(K, V, Context)` is an allocator-taking, dynamically-growing hash map.
// It uses OPEN ADDRESSING with LINEAR PROBING and TOMBSTONE deletion over three
// parallel heap slices (`keys`/`vals`/`state`), so there is no per-entry node
// allocation and no fn-pointer-of-node — every lookup is index math the VM and
// native backend handle cleanly. Capacity is always a power of two, so the slot
// index is a cheap `hash & (cap-1)` mask; the table grows (doubling) and rehashes
// when the used+tombstone load reaches 75%, which also reclaims tombstones.
//
// HASH/EQ ARE A COMPTIME CONTEXT TYPE, not a derived-from-`K` trait: `Context` is
// a `struct` exposing `pub fn hash(K) u64` and `pub fn eql(K, K) bool`, invoked
// from inside the map's own methods. This is the only function-dispatch shape the
// language supports for passing behavior into a generic container (a function
// *value* cannot be passed). `IntContext` (multiplicative/Fibonacci hash) and
// `StrContext` (FNV-1a folded to 32 bits) are bundled, with the thin wrappers
// `IntHashMap`/`StringHashMap`/`AutoHashMap` binding the right one.
//
// OWNERSHIP: the map owns ONLY its three slices and frees them with its stored
// allocator on `deinit`. For `[]const u8` keys/values the BYTES are borrowed —
// the caller owns and frees them; the map stores the slice headers.
pub fn HashMap(comptime K: type, comptime V: type, comptime Context: type) type {
    return struct {
        const Self = @This();

        /// The keys, one per slot; meaningful only where `state[i] == 1` (USED).
        keys: []K,
        /// The values, parallel to `keys`.
        vals: []V,
        /// Per-slot occupancy: `0` = EMPTY, `1` = USED, `2` = TOMB (a deleted
        /// slot that still has to be probed past). Inline integer literals are
        /// used everywhere instead of named constants — a struct-body typed
        /// `const EMPTY: u8 = 0;` is currently mis-resolved as a TYPE, so the
        /// three states are written as the literals `0`/`1`/`2` throughout.
        state: []u8,
        /// The number of live (USED) entries — what `count()` returns.
        live: usize,
        /// Used + tombstones: the occupancy that drives growth. Grows reset it.
        upt: usize,
        /// The allocator the three slices are owned through.
        alloc: Allocator,

        /// One live key/value pair, yielded by the iterator.
        pub const Entry = struct {
            /// The entry's key.
            key: K,
            /// The entry's value.
            value: V,
        };

        /// The result of `getOrPut`: a pointer to the slot's value (so the caller
        /// can read or overwrite it in place) plus whether the key already existed.
        pub const GetOrPutResult = struct {
            /// A pointer into `vals[]`, valid until the next insert that grows.
            value_ptr: *V,
            /// `true` if the key was already present (the value is the old one).
            found_existing: bool,
        };

        /// A forward iterator over the live entries, in arbitrary (slot) order.
        /// Construct with `map.iterator()` and drive with `while (it.next()) |e|`.
        pub const Iterator = struct {
            /// The map being walked.
            map: *Self,
            /// The next slot index to examine.
            idx: usize,

            /// The next live entry, or `null` once every slot has been visited.
            pub fn next(self: *Iterator) ?Entry {
                while (self.idx < self.map.state.len) {
                    const i = self.idx;
                    self.idx += 1;
                    if (self.map.state[i] == 1) {
                        return Entry{ .key = self.map.keys[i], .value = self.map.vals[i] };
                    }
                }
                return null;
            }
        };

        /// An empty map bound to `alloc`. No storage is allocated until the first
        /// `put` — an empty map is free.
        pub fn init(alloc: Allocator) Self {
            return Self{
                .keys = &.{},
                .vals = &.{},
                .state = &.{},
                .live = 0,
                .upt = 0,
                .alloc = alloc,
            };
        }

        /// Release the three backing slices with the map's own allocator. Borrowed
        /// key/value bytes (for `[]const u8`) are the caller's to free.
        pub fn deinit(self: *Self) void {
            if (self.state.len != 0) {
                self.alloc.free(self.keys);
                self.alloc.free(self.vals);
                self.alloc.free(self.state);
            }
        }

        /// Locate the slot for `key`. On return `found.*` is `true` and the result
        /// is the existing slot iff the key is present; otherwise the result is the
        /// first reusable slot for insertion — the first TOMBSTONE seen while
        /// probing, or the first EMPTY slot. Remembering the first tombstone keeps
        /// reinsertion O(1) and bounds probe length under deletion churn.
        fn findSlot(self: *Self, key: K, found: *bool) usize {
            const m = self.state.len - 1;
            const start: usize = @as(usize, @intCast(Context.hash(key))) & m;
            var i: usize = start;
            var first_tomb: usize = 0;
            var have_tomb: bool = false;
            while (true) {
                const st = self.state[i];
                if (st == 0) {
                    found.* = false;
                    if (have_tomb) return first_tomb;
                    return i;
                }
                if (st == 1) {
                    if (Context.eql(self.keys[i], key)) {
                        found.* = true;
                        return i;
                    }
                } else {
                    // A tombstone: a candidate insertion slot, but keep probing in
                    // case the key itself lives further along the run.
                    if (not have_tomb) {
                        have_tomb = true;
                        first_tomb = i;
                    }
                }
                i = (i + 1) & m;
                if (i == start) {
                    // Wrapped the whole table without an empty slot (degenerate:
                    // table full of used+tomb). Fall back to the first tombstone.
                    found.* = false;
                    if (have_tomb) return first_tomb;
                    return i;
                }
            }
        }

        /// Allocate a fresh table (double the capacity, floor 8), zero its state,
        /// and rehash only the USED slots — which drops every tombstone and resets
        /// `upt` to the live count, restoring short probe runs. The old storage is
        /// freed afterward.
        fn grow(self: *Self) !void {
            const new_cap: usize = if (self.state.len == 0) 8 else self.state.len * 2;
            const new_keys = try self.alloc.alloc(K, new_cap);
            const new_vals = try self.alloc.alloc(V, new_cap);
            const new_state = try self.alloc.alloc(u8, new_cap);
            var j: usize = 0;
            while (j < new_cap) : (j += 1) {
                new_state[j] = 0;
            }
            const old_keys = self.keys;
            const old_vals = self.vals;
            const old_state = self.state;
            const old_len = old_state.len;
            // Re-point to the fresh table, then rehash the live entries into it.
            self.keys = new_keys;
            self.vals = new_vals;
            self.state = new_state;
            self.live = 0;
            self.upt = 0;
            var k: usize = 0;
            while (k < old_len) : (k += 1) {
                if (old_state[k] == 1) {
                    var f: bool = false;
                    const slot = self.findSlot(old_keys[k], &f);
                    self.keys[slot] = old_keys[k];
                    self.vals[slot] = old_vals[k];
                    self.state[slot] = 1;
                    self.live += 1;
                    self.upt += 1;
                }
            }
            if (old_len != 0) {
                self.alloc.free(old_keys);
                self.alloc.free(old_vals);
                self.alloc.free(old_state);
            }
        }

        /// Insert or update `key -> value`, growing first if the next insert would
        /// push the used+tombstone load to/over 75% (`(upt+1)*4 >= cap*3`). A
        /// present key is overwritten in place; a fresh key takes the first empty
        /// or tombstone slot.
        pub fn put(self: *Self, key: K, value: V) !void {
            if ((self.upt + 1) * 4 >= self.state.len * 3) {
                try self.grow();
            }
            var f: bool = false;
            const slot = self.findSlot(key, &f);
            if (f) {
                self.vals[slot] = value;
                return;
            }
            // Filling an EMPTY slot raises used+tombstones; reusing a TOMB does not.
            if (self.state[slot] == 0) {
                self.upt += 1;
            }
            self.state[slot] = 1;
            self.keys[slot] = key;
            self.vals[slot] = value;
            self.live += 1;
        }

        /// The value mapped to `key`, or `null` if absent.
        pub fn get(self: *Self, key: K) ?V {
            if (self.state.len == 0) return null;
            var f: bool = false;
            const slot = self.findSlot(key, &f);
            if (f) return self.vals[slot];
            return null;
        }

        /// The address of value slot `slot`. Isolated in its own method ON PURPOSE:
        /// taking `&self.vals[slot]` in a method body that ALSO stored into another
        /// field of `*self` first currently mis-lowers the interior pointer, so
        /// `getOrPut`/`getPtr` route every `&self.vals[i]` through this clean helper
        /// (whose body does nothing but take the address). The returned pointer is
        /// valid until the next insert that grows the table.
        fn valuePtr(self: *Self, slot: usize) *V {
            return &self.vals[slot];
        }

        /// A pointer to the value mapped to `key`, or `null` if absent. The pointer
        /// is valid until the next insert that triggers a grow (which moves storage).
        pub fn getPtr(self: *Self, key: K) ?*V {
            if (self.state.len == 0) return null;
            var f: bool = false;
            const slot = self.findSlot(key, &f);
            if (f) return self.valuePtr(slot);
            return null;
        }

        /// Find `key`, inserting a slot for it if absent. Returns a pointer to the
        /// (new or existing) value plus whether it already existed — the canonical
        /// "increment a counter, defaulting to one" primitive. A newly created slot
        /// holds an UNDEFINED value the caller must initialize through `value_ptr`.
        pub fn getOrPut(self: *Self, key: K) !GetOrPutResult {
            if ((self.upt + 1) * 4 >= self.state.len * 3) {
                try self.grow();
            }
            var f: bool = false;
            const slot = self.findSlot(key, &f);
            if (f) {
                return GetOrPutResult{ .value_ptr = self.valuePtr(slot), .found_existing = true };
            }
            if (self.state[slot] == 0) {
                self.upt += 1;
            }
            self.state[slot] = 1;
            self.keys[slot] = key;
            self.live += 1;
            return GetOrPutResult{ .value_ptr = self.valuePtr(slot), .found_existing = false };
        }

        /// `true` if `key` is present.
        pub fn contains(self: *Self, key: K) bool {
            if (self.state.len == 0) return false;
            var f: bool = false;
            _ = self.findSlot(key, &f);
            return f;
        }

        /// Remove `key`, returning `true` if it was present. The slot becomes a
        /// TOMBSTONE (probing past it still works); a later `put` of any key may
        /// reuse it.
        pub fn remove(self: *Self, key: K) bool {
            if (self.state.len == 0) return false;
            var f: bool = false;
            const slot = self.findSlot(key, &f);
            if (not f) return false;
            self.state[slot] = 2;
            self.live -= 1;
            return true;
        }

        /// The number of live entries.
        pub fn count(self: *Self) usize {
            return self.live;
        }

        /// A forward iterator over the live entries (arbitrary order).
        pub fn iterator(self: *Self) Iterator {
            return Iterator{ .map = self, .idx = 0 };
        }
    };
}

/// The hash/eq `Context` FACTORY for INTEGER keys of type `K` (any width that
/// coerces to `u64`). `IntContext(K)` yields a `struct` with concrete-typed
/// `hash`/`eql` — a factory rather than a single `anytype` struct because a
/// context method must take the CONCRETE key type to monomorphize correctly
/// (an `anytype` context method mis-infers its return type inside a generic).
///
/// The hash is a Fibonacci/Knuth multiplicative mix written to be OVERFLOW-FREE
/// in safe builds: each 32-bit half of the key is multiplied by the golden-ratio
/// constant and masked back to 32 bits before the products can exceed `u64`, so
/// it never traps. The two halves are XOR-folded so high bits of wide keys matter.
pub fn IntContext(comptime K: type) type {
    return struct {
        /// Hash an integer key to a 64-bit value (low 32 bits carry the entropy
        /// used by the power-of-two slot mask).
        pub fn hash(k: K) u64 {
            const m: u64 = 0xFFFFFFFF;
            const knuth: u64 = 2654435761;
            const w: u64 = @intCast(k);
            const lo: u64 = w & m;
            const hi: u64 = (w >> 32) & m;
            return ((lo * knuth) & m) ^ ((hi * knuth) & m);
        }

        /// Integer key equality.
        pub fn eql(a: K, b: K) bool {
            return a == b;
        }
    };
}

/// The hash/eq `Context` for `[]const u8` (string / byte-slice) keys. The hash is
/// FNV-1a folded into 32 bits at every step so the running product never exceeds
/// `u64` (overflow-free in safe builds); `eql` is a length-then-byte compare,
/// identical to `mem.eql(u8, a, b)`.
pub const StrContext = struct {
    /// FNV-1a over the bytes, masked to 32 bits each step.
    pub fn hash(s: []const u8) u64 {
        var h: u64 = 2166136261;
        const prime: u64 = 16777619;
        const m: u64 = 0xFFFFFFFF;
        var i: usize = 0;
        while (i < s.len) : (i += 1) {
            h = h ^ @as(u64, s[i]);
            h = (h * prime) & m;
        }
        return h;
    }

    /// Byte-slice key equality.
    pub fn eql(a: []const u8, b: []const u8) bool {
        if (a.len != b.len) return false;
        var i: usize = 0;
        while (i < a.len) : (i += 1) {
            if (a[i] != b[i]) return false;
        }
        return true;
    }
};

/// `HashMap` specialized to integer keys with the bundled `IntContext(K)`.
pub fn IntHashMap(comptime K: type, comptime V: type) type {
    return HashMap(K, V, IntContext(K));
}

/// `HashMap` specialized to `[]const u8` (string) keys with the bundled
/// `StrContext`. The classic word-count / interning map.
pub fn StringHashMap(comptime V: type) type {
    return HashMap([]const u8, V, StrContext);
}

/// The convenience map for INTEGER keys — `AutoHashMap(K, V)` binds the bundled
/// `IntContext(K)`, so it is exactly `IntHashMap(K, V)`.
///
/// LIMITATION (documented): the spec's fully-automatic key dispatch — selecting
/// `StrContext` for a `[]const u8` key, `IntContext` otherwise, at comptime —
/// would require folding `mem.eql(@typeName(K), "[]const u8")` to a comptime
/// `bool` inside a type-returning branch. That comptime fold is not yet performed
/// (both `type`-valued branches are then checked and fail to unify), so the auto
/// form covers the integer case here and STRING keys use `StringHashMap(V)`
/// directly. Both rest on the same `HashMap(K, V, Context)` core.
pub fn AutoHashMap(comptime K: type, comptime V: type) type {
    return HashMap(K, V, IntContext(K));
}

// =========================================================================
//  sort — in-place comparison sorting (introsort-lite) + search
// =========================================================================
//
// `Sorter(T, Context)` sorts a `[]T` IN PLACE with no allocation. The algorithm
// is quicksort (median-of-three-ish `arr[mid]` pivot, Hoare partition) with an
// insertion-sort cutoff for short ranges (`< 16`), plus a standalone stable
// insertion sort, `isSorted`, and `binarySearch`.
//
// As with `HashMap`, the ORDER is a comptime `Context` type exposing
// `pub fn lessThan(a: T, b: T) bool`, invoked from inside the engine's methods —
// the spec's `sort(T, slice, ctx, lessThan)` fn-value signature is not expressible
// (a function cannot be passed by value), so the surface is `Sorter(T, Asc).sort(s)`.
// `asc(T)`/`desc(T)` build ascending/descending contexts for any ordered scalar.
pub const sort = struct {
    /// An ascending-order context for any scalar `T` supporting `<` (the default
    /// comparison order). `sort.asc(i32)` is the `Context` for `Sorter`.
    pub fn asc(comptime T: type) type {
        return struct {
            /// `a` precedes `b` iff `a < b` — ascending order.
            pub fn lessThan(a: T, b: T) bool {
                return a < b;
            }
        };
    }

    /// A descending-order context for any scalar `T` supporting `>`. Sorting with
    /// `sort.desc(T)` orders largest-first.
    pub fn desc(comptime T: type) type {
        return struct {
            /// `a` precedes `b` iff `a > b` — descending order.
            pub fn lessThan(a: T, b: T) bool {
                return a > b;
            }
        };
    }

    /// The in-place sort/search engine over `[]T`, ordered by `Context.lessThan`.
    pub fn Sorter(comptime T: type, comptime Context: type) type {
        return struct {
            /// Stable insertion sort of the inclusive range `arr[lo..=hi]`. O(n^2)
            /// in the worst case but optimal on short or nearly-sorted ranges,
            /// which is exactly where quicksort hands off.
            fn insertionRange(arr: []T, lo: usize, hi: usize) void {
                var i: usize = lo + 1;
                while (i <= hi) : (i += 1) {
                    const key = arr[i];
                    var j: usize = i;
                    while (j > lo and Context.lessThan(key, arr[j - 1])) : (j -= 1) {
                        arr[j] = arr[j - 1];
                    }
                    arr[j] = key;
                }
            }

            /// Quicksort the inclusive range `arr[lo..=hi]`, falling back to
            /// insertion sort below the cutoff. The Hoare partition meets in the
            /// middle, then recurses on `[lo..=j]` and `[j+1..=hi]`.
            fn quick(arr: []T, lo: usize, hi: usize) void {
                if (hi <= lo) return;
                if (hi - lo < 16) {
                    insertionRange(arr, lo, hi);
                    return;
                }
                const mid = lo + (hi - lo) / 2;
                const pivot = arr[mid];
                var i: usize = lo;
                var j: usize = hi;
                while (true) {
                    while (Context.lessThan(arr[i], pivot)) : (i += 1) {}
                    while (Context.lessThan(pivot, arr[j])) : (j -= 1) {}
                    if (i >= j) {
                        if (j > lo) quick(arr, lo, j);
                        if (j + 1 <= hi) quick(arr, j + 1, hi);
                        return;
                    }
                    const tmp = arr[i];
                    arr[i] = arr[j];
                    arr[j] = tmp;
                    i += 1;
                    j -= 1;
                }
            }

            /// Sort `arr` in place in ascending `Context` order. O(n log n) expected.
            pub fn sort(arr: []T) void {
                if (arr.len < 2) return;
                quick(arr, 0, arr.len - 1);
            }

            /// A stable insertion sort of the whole slice (O(n^2); use for small or
            /// nearly-sorted inputs where a stable order matters).
            pub fn insertionSort(arr: []T) void {
                if (arr.len < 2) return;
                insertionRange(arr, 0, arr.len - 1);
            }

            /// An in-place heap sort: O(n log n) WORST case and no extra memory (the
            /// guarantee `sort`'s quicksort can't make on an adversarial input).
            /// Builds a max-heap, then repeatedly moves the root to the shrinking
            /// tail.
            pub fn heapSort(arr: []T) void {
                const n = arr.len;
                if (n < 2) return;
                // Heapify: sift down every internal node, last parent first.
                var start: usize = n / 2;
                while (start > 0) {
                    start -= 1;
                    siftDown(arr, start, n);
                }
                // Extract: swap the max (root) to the end, then restore the heap.
                var end: usize = n;
                while (end > 1) {
                    end -= 1;
                    const t = arr[0];
                    arr[0] = arr[end];
                    arr[end] = t;
                    siftDown(arr, 0, end);
                }
            }

            /// Restore the max-heap property at `start` within `arr[0..end]`.
            fn siftDown(arr: []T, start: usize, end: usize) void {
                var root = start;
                while (2 * root + 1 < end) {
                    var child = 2 * root + 1;
                    if (child + 1 < end and Context.lessThan(arr[child], arr[child + 1])) {
                        child += 1;
                    }
                    if (Context.lessThan(arr[root], arr[child])) {
                        const t = arr[root];
                        arr[root] = arr[child];
                        arr[child] = t;
                        root = child;
                    } else {
                        return;
                    }
                }
            }

            /// A STABLE merge sort using one allocator-owned scratch buffer of
            /// `arr.len` elements (freed before return). O(n log n) guaranteed, and
            /// — unlike `sort`/`heapSort` — equal elements keep their input order.
            /// Fails only if the allocator is exhausted.
            pub fn mergeSort(arr: []T, alloc: Allocator) !void {
                if (arr.len < 2) return;
                const scratch = try alloc.alloc(T, arr.len);
                defer alloc.free(scratch);
                mergeRange(arr, scratch, 0, arr.len);
            }

            /// Sort `arr[lo..hi]` in place, merging through `scratch`.
            fn mergeRange(arr: []T, scratch: []T, lo: usize, hi: usize) void {
                if (hi - lo < 2) return;
                const mid = lo + (hi - lo) / 2;
                mergeRange(arr, scratch, lo, mid);
                mergeRange(arr, scratch, mid, hi);
                // Merge the two sorted halves into scratch (left wins ties → stable).
                var i: usize = lo;
                var j: usize = mid;
                var k: usize = lo;
                while (i < mid and j < hi) {
                    if (Context.lessThan(arr[j], arr[i])) {
                        scratch[k] = arr[j];
                        j += 1;
                    } else {
                        scratch[k] = arr[i];
                        i += 1;
                    }
                    k += 1;
                }
                while (i < mid) {
                    scratch[k] = arr[i];
                    i += 1;
                    k += 1;
                }
                while (j < hi) {
                    scratch[k] = arr[j];
                    j += 1;
                    k += 1;
                }
                // Copy the merged run back.
                k = lo;
                while (k < hi) : (k += 1) arr[k] = scratch[k];
            }

            /// `true` if `arr` is already in non-decreasing `Context` order.
            pub fn isSorted(arr: []const T) bool {
                var i: usize = 1;
                while (i < arr.len) : (i += 1) {
                    if (Context.lessThan(arr[i], arr[i - 1])) return false;
                }
                return true;
            }

            /// Binary search a slice ALREADY SORTED in `Context` order; returns the
            /// index of a matching element, or `null` if absent. "Match" means
            /// neither `a < b` nor `b < a` under the comparator.
            pub fn binarySearch(arr: []const T, target: T) ?usize {
                var lo: usize = 0;
                var hi: usize = arr.len;
                while (lo < hi) {
                    const mid = lo + (hi - lo) / 2;
                    if (Context.lessThan(arr[mid], target)) {
                        lo = mid + 1;
                    } else if (Context.lessThan(target, arr[mid])) {
                        hi = mid;
                    } else {
                        return mid;
                    }
                }
                return null;
            }

            /// The first index `i` in the sorted `arr` where `target` could be
            /// inserted to keep it sorted — i.e. the count of elements strictly
            /// LESS than `target` (`std::lower_bound`). In `[0, arr.len]`.
            pub fn lowerBound(arr: []const T, target: T) usize {
                var lo: usize = 0;
                var hi: usize = arr.len;
                while (lo < hi) {
                    const mid = lo + (hi - lo) / 2;
                    if (Context.lessThan(arr[mid], target)) {
                        lo = mid + 1;
                    } else {
                        hi = mid;
                    }
                }
                return lo;
            }

            /// The first index `i` in the sorted `arr` strictly PAST every element
            /// `<= target` — i.e. the count of elements not greater than `target`
            /// (`std::upper_bound`). `upperBound - lowerBound` is the multiplicity
            /// of `target`.
            pub fn upperBound(arr: []const T, target: T) usize {
                var lo: usize = 0;
                var hi: usize = arr.len;
                while (lo < hi) {
                    const mid = lo + (hi - lo) / 2;
                    if (Context.lessThan(target, arr[mid])) {
                        hi = mid;
                    } else {
                        lo = mid + 1;
                    }
                }
                return lo;
            }

            /// Lomuto partition of `arr[lo..=hi]` around `arr[hi]`: moves smaller
            /// elements left, returns the pivot's final index.
            fn lomuto(arr: []T, lo: usize, hi: usize) usize {
                const pivot = arr[hi];
                var i = lo;
                var j = lo;
                while (j < hi) : (j += 1) {
                    if (Context.lessThan(arr[j], pivot)) {
                        const t = arr[i];
                        arr[i] = arr[j];
                        arr[j] = t;
                        i += 1;
                    }
                }
                const t = arr[i];
                arr[i] = arr[hi];
                arr[hi] = t;
                return i;
            }

            /// The `k`-th smallest element (0-indexed) of `arr`, found in O(n)
            /// average time by Hoare's quickselect — partitioning in place toward
            /// the target rank without a full sort. `null` if `k >= arr.len`. NOTE:
            /// `arr` is PARTIALLY reordered (everything `< result` ends up before
            /// index `k`); pass a scratch copy if you need the original order.
            pub fn quickselect(arr: []T, k: usize) ?T {
                if (k >= arr.len) return null;
                var lo: usize = 0;
                var hi: usize = arr.len - 1;
                while (true) {
                    if (lo == hi) return arr[lo];
                    const p = lomuto(arr, lo, hi);
                    if (p == k) return arr[k];
                    if (k < p) {
                        hi = p - 1; // p > k >= 0, so p >= 1, no underflow
                    } else {
                        lo = p + 1;
                    }
                }
            }

            /// The lower median of `arr` (the `(len-1)/2`-th smallest), by
            /// quickselect. `null` for an empty slice. Reorders `arr`.
            pub fn median(arr: []T) ?T {
                if (arr.len == 0) return null;
                return quickselect(arr, (arr.len - 1) / 2);
            }
        };
    }
};

// =========================================================================
//  RingBuffer — a fixed-capacity circular FIFO queue
// =========================================================================

/// A bounded first-in-first-out queue over a single allocator-owned buffer of
/// `capacity + 1` slots (one slot is kept empty to distinguish full from empty).
/// `push`/`pop` are O(1) with no per-element allocation; the whole buffer is freed
/// once in `deinit`. Allocator-owned, like `ArrayList`.
pub fn RingBuffer(comptime T: type) type {
    return struct {
        const Self = @This();

        buf: []T,
        head: usize, // index of the front element
        tail: usize, // index one past the back element
        alloc: Allocator,

        /// A ring holding up to `capacity` elements (one extra slot is reserved).
        pub fn init(alloc: Allocator, capacity: usize) !Self {
            const slots = try alloc.alloc(T, capacity + 1);
            return Self{ .buf = slots, .head = 0, .tail = 0, .alloc = alloc };
        }

        /// Free the backing buffer.
        pub fn deinit(self: *Self) void {
            if (self.buf.len != 0) self.alloc.free(self.buf);
        }

        /// The number of buffered elements.
        pub fn len(self: *const Self) usize {
            if (self.tail >= self.head) return self.tail - self.head;
            return self.buf.len - self.head + self.tail;
        }

        /// `true` if no elements are buffered.
        pub fn isEmpty(self: *const Self) bool {
            return self.head == self.tail;
        }

        /// `true` if the ring cannot hold another element.
        pub fn isFull(self: *const Self) bool {
            return (self.tail + 1) % self.buf.len == self.head;
        }

        /// Enqueue `value` at the back; returns `error.NoSpaceLeft`-style refusal as
        /// `false` (the ring is full) or `true` on success.
        pub fn push(self: *Self, value: T) bool {
            if (self.isFull()) return false;
            self.buf[self.tail] = value;
            self.tail = (self.tail + 1) % self.buf.len;
            return true;
        }

        /// Dequeue the front element, or `null` if empty.
        pub fn pop(self: *Self) ?T {
            if (self.isEmpty()) return null;
            const v = self.buf[self.head];
            self.head = (self.head + 1) % self.buf.len;
            return v;
        }

        /// The front element without removing it, or `null` if empty.
        pub fn peek(self: *const Self) ?T {
            if (self.isEmpty()) return null;
            return self.buf[self.head];
        }
    };
}

// =========================================================================
//  BitSet — a dense, allocator-owned bit array
// =========================================================================

/// A dense bit array of a fixed bit-count, packed into allocator-owned `u64`
/// words. `set`/`clear`/`isSet` are O(1); `popcount` scans the words. The whole
/// word array is freed once in `deinit`.
pub const BitSet = struct {
    const Self = @This();

    words: []u64,
    bits: usize,
    alloc: Allocator,

    /// A bit set of `bit_count` bits, all initially clear.
    pub fn init(alloc: Allocator, bit_count: usize) !Self {
        const n = (bit_count + 63) / 64;
        const words = try alloc.alloc(u64, n);
        var i: usize = 0;
        while (i < n) : (i += 1) words[i] = 0;
        return Self{ .words = words, .bits = bit_count, .alloc = alloc };
    }

    /// Free the backing words.
    pub fn deinit(self: *Self) void {
        if (self.words.len != 0) self.alloc.free(self.words);
    }

    /// Set bit `i` (must be `< bits`).
    pub fn set(self: *Self, i: usize) void {
        self.words[i / 64] = self.words[i / 64] | (@as(u64, 1) << @as(u6, @intCast(i % 64)));
    }

    /// Clear bit `i`.
    pub fn clear(self: *Self, i: usize) void {
        self.words[i / 64] = self.words[i / 64] & ~(@as(u64, 1) << @as(u6, @intCast(i % 64)));
    }

    /// `true` if bit `i` is set.
    pub fn isSet(self: *const Self, i: usize) bool {
        return (self.words[i / 64] >> @as(u6, @intCast(i % 64))) & 1 == 1;
    }

    /// The number of set bits.
    pub fn popcount(self: *const Self) usize {
        var n: usize = 0;
        var w: usize = 0;
        while (w < self.words.len) : (w += 1) {
            n += @as(usize, math.popcount(self.words[w]));
        }
        return n;
    }
};

// =========================================================================
//  Deque — a growable double-ended queue (ring buffer with wrap-around)
// =========================================================================

/// A double-ended queue: amortized-O(1) push/pop at BOTH ends, backed by a
/// growable ring buffer that doubles (from a floor of 8) when full. Allocator-
/// owned, like `ArrayList`; `deinit` frees the one backing buffer.
pub fn Deque(comptime T: type) type {
    return struct {
        const Self = @This();

        buf: []T,
        head: usize, // index of the front element
        count: usize, // number of live elements
        alloc: Allocator,

        /// An empty deque bound to `alloc`.
        pub fn init(alloc: Allocator) Self {
            return Self{ .buf = &.{}, .head = 0, .count = 0, .alloc = alloc };
        }

        /// Free the backing buffer.
        pub fn deinit(self: *Self) void {
            if (self.buf.len != 0) self.alloc.free(self.buf);
        }

        /// The number of buffered elements.
        pub fn len(self: *const Self) usize {
            return self.count;
        }

        /// `true` if empty.
        pub fn isEmpty(self: *const Self) bool {
            return self.count == 0;
        }

        /// Grow to at least `need` capacity, copying the live elements into logical
        /// order at the front of the new buffer (head reset to 0).
        fn ensureCapacity(self: *Self, need: usize) !void {
            if (need <= self.buf.len) return;
            var new_cap: usize = if (self.buf.len == 0) 8 else self.buf.len * 2;
            if (new_cap < need) new_cap = need;
            const fresh = try self.alloc.alloc(T, new_cap);
            var i: usize = 0;
            while (i < self.count) : (i += 1) {
                fresh[i] = self.buf[(self.head + i) % self.buf.len];
            }
            if (self.buf.len != 0) self.alloc.free(self.buf);
            self.buf = fresh;
            self.head = 0;
        }

        /// Append `value` at the back.
        pub fn pushBack(self: *Self, value: T) !void {
            try self.ensureCapacity(self.count + 1);
            self.buf[(self.head + self.count) % self.buf.len] = value;
            self.count += 1;
        }

        /// Prepend `value` at the front.
        pub fn pushFront(self: *Self, value: T) !void {
            try self.ensureCapacity(self.count + 1);
            self.head = (self.head + self.buf.len - 1) % self.buf.len;
            self.buf[self.head] = value;
            self.count += 1;
        }

        /// Remove and return the front element, or `null` if empty.
        pub fn popFront(self: *Self) ?T {
            if (self.count == 0) return null;
            const v = self.buf[self.head];
            self.head = (self.head + 1) % self.buf.len;
            self.count -= 1;
            return v;
        }

        /// Remove and return the back element, or `null` if empty.
        pub fn popBack(self: *Self) ?T {
            if (self.count == 0) return null;
            self.count -= 1;
            return self.buf[(self.head + self.count) % self.buf.len];
        }

        /// The front element without removing it, or `null` if empty.
        pub fn front(self: *const Self) ?T {
            if (self.count == 0) return null;
            return self.buf[self.head];
        }

        /// The back element without removing it, or `null` if empty.
        pub fn back(self: *const Self) ?T {
            if (self.count == 0) return null;
            return self.buf[(self.head + self.count - 1) % self.buf.len];
        }

        /// Bounds-checked access by logical index (`0` is the front), or `null`.
        pub fn get(self: *const Self, index: usize) ?T {
            if (index >= self.count) return null;
            return self.buf[(self.head + index) % self.buf.len];
        }
    };
}

// =========================================================================
//  BstNode — a self-referential binary-search-tree node
// =========================================================================

/// A binary-search-tree NODE for an ordered, comparable `T` (uses `<`/`>`). The
/// recursive children are `?*@This()`; child nodes are heap-allocated through the
/// passed allocator. This is the node, not a wrapper: the caller owns the ROOT (on
/// the stack or the heap) and frees the heap-allocated descendants with
/// `freeChildren`. A clean generic *wrapper* (`root: ?*Node`) awaits the
/// nested-type-const fix; the node API is fully usable today.
pub fn BstNode(comptime T: type) type {
    return struct {
        const Self = @This();

        value: T,
        left: ?*@This(),
        right: ?*@This(),

        /// A leaf node holding `value` (no children).
        pub fn leaf(value: T) Self {
            return Self{ .value = value, .left = null, .right = null };
        }

        /// Insert `value` into the subtree rooted at `self` (duplicates ignored),
        /// allocating one node for it. The allocation escapes into a child link, so
        /// `freeChildren` must eventually release it.
        pub fn insert(self: *Self, alloc: Allocator, value: T) !void {
            if (value < self.value) {
                if (self.left) |l| {
                    try l.insert(alloc, value);
                } else {
                    const n = try alloc.create(Self);
                    n.* = Self.leaf(value);
                    self.left = n;
                }
            } else if (value > self.value) {
                if (self.right) |r| {
                    try r.insert(alloc, value);
                } else {
                    const n = try alloc.create(Self);
                    n.* = Self.leaf(value);
                    self.right = n;
                }
            }
        }

        /// `true` if `value` is present in the subtree.
        pub fn contains(self: *const Self, value: T) bool {
            if (value == self.value) return true;
            if (value < self.value) {
                if (self.left) |l| return l.contains(value);
                return false;
            }
            if (self.right) |r| return r.contains(value);
            return false;
        }

        /// The number of nodes in the subtree (including `self`).
        pub fn count(self: *const Self) usize {
            var n: usize = 1;
            if (self.left) |l| n += l.count();
            if (self.right) |r| n += r.count();
            return n;
        }

        /// The height of the subtree (a single leaf has height 1).
        pub fn height(self: *const Self) usize {
            const hl: usize = if (self.left) |l| l.height() else 0;
            const hr: usize = if (self.right) |r| r.height() else 0;
            return 1 + (if (hl > hr) hl else hr);
        }

        /// The smallest value in the subtree (the leftmost node).
        pub fn min(self: *const Self) T {
            var cur = self;
            while (cur.left) |l| cur = l;
            return cur.value;
        }

        /// The largest value in the subtree (the rightmost node).
        pub fn max(self: *const Self) T {
            var cur = self;
            while (cur.right) |r| cur = r;
            return cur.value;
        }

        /// Free every heap-allocated DESCENDANT (not `self`, which the caller owns).
        /// After this the node is a leaf again.
        pub fn freeChildren(self: *Self, alloc: Allocator) void {
            if (self.left) |l| {
                l.freeChildren(alloc);
                alloc.destroy(l);
            }
            if (self.right) |r| {
                r.freeChildren(alloc);
                alloc.destroy(r);
            }
            self.left = null;
            self.right = null;
        }
    };
}

// =========================================================================
//  rand — a small seedable pseudo-random generator (xorshift64)
// =========================================================================

/// A deterministic, seedable PRNG (Marsaglia `xorshift64`) for non-cryptographic
/// uses: shuffling, sampling, randomized tests. Same seed → same sequence on every
/// target. Pure XOR/shift (no wrapping multiply), so it never traps. NOT for
/// security. (The testing module's `fuzzInput` is the host-driven fuzz source;
/// this is an in-program generator you control.)
pub const Random = struct {
    const Self = @This();

    state: u64,

    /// A generator seeded with `seed` (a `0` seed is nudged to avoid the
    /// xorshift fixed point).
    pub fn init(seed: u64) Self {
        return Self{ .state = if (seed == 0) 0x9E3779B97F4A7C15 else seed };
    }

    /// The next 64-bit value, advancing the state (`xorshift64`). Only XOR and
    /// shifts — bits shifted past the width are discarded, never an overflow trap.
    pub fn next(self: *Self) u64 {
        var x = self.state;
        x = x ^ (x << 13);
        x = x ^ (x >> 7);
        x = x ^ (x << 17);
        self.state = x;
        return x;
    }

    /// A value in `[0, bound)` (uniform enough for non-crypto use; `bound == 0`
    /// returns `0`).
    pub fn below(self: *Self, bound: u64) u64 {
        if (bound == 0) return 0;
        return self.next() % bound;
    }

    /// A value in the inclusive range `[lo, hi]` (`lo <= hi`).
    pub fn intRange(self: *Self, lo: u64, hi: u64) u64 {
        return lo + self.below(hi - lo + 1);
    }

    /// A fair coin: `true` or `false`.
    pub fn boolean(self: *Self) bool {
        return self.next() & 1 == 1;
    }

    /// Shuffle `slice` in place with the Fisher–Yates algorithm (every permutation
    /// equally likely, modulo the generator's quality). O(n).
    pub fn shuffle(self: *Self, comptime T: type, slice: []T) void {
        if (slice.len < 2) return;
        var i: usize = slice.len;
        while (i > 1) {
            i -= 1;
            const j = @as(usize, @intCast(self.below(@as(u64, i) + 1)));
            const t = slice[i];
            slice[i] = slice[j];
            slice[j] = t;
        }
    }

    /// A uniformly-random element of `slice`, or `null` if it is empty.
    pub fn choice(self: *Self, comptime T: type, slice: []const T) ?T {
        if (slice.len == 0) return null;
        const i = @as(usize, @intCast(self.below(@as(u64, slice.len))));
        return slice[i];
    }
};

// =========================================================================
//  ascii — single-byte classification and case
// =========================================================================

/// Pure, single-byte ASCII classification and case folding. Every function is a
/// total function on a `u8`; non-ASCII bytes (>= 0x80) classify as "not" and are
/// returned unchanged by the case folders.
pub const ascii = struct {
    /// `true` for `'0'..='9'`.
    pub fn isDigit(c: u8) bool {
        return c >= '0' and c <= '9';
    }

    /// `true` for `'a'..='z'` or `'A'..='Z'`.
    pub fn isAlpha(c: u8) bool {
        return (c >= 'a' and c <= 'z') or (c >= 'A' and c <= 'Z');
    }

    /// `true` for a letter or a digit.
    pub fn isAlphanumeric(c: u8) bool {
        return isAlpha(c) or isDigit(c);
    }

    /// `true` for space, tab, newline, carriage return, vertical tab, or form feed.
    pub fn isWhitespace(c: u8) bool {
        return c == ' ' or c == '\t' or c == '\n' or c == '\r' or c == 11 or c == 12;
    }

    /// Lowercase an ASCII letter; any other byte is returned unchanged.
    pub fn toLower(c: u8) u8 {
        if (c >= 'A' and c <= 'Z') return c + 32;
        return c;
    }

    /// Uppercase an ASCII letter; any other byte is returned unchanged.
    pub fn toUpper(c: u8) u8 {
        if (c >= 'a' and c <= 'z') return c - 32;
        return c;
    }

    /// `true` for an uppercase ASCII letter `'A'..='Z'`.
    pub fn isUpper(c: u8) bool {
        return c >= 'A' and c <= 'Z';
    }

    /// `true` for a lowercase ASCII letter `'a'..='z'`.
    pub fn isLower(c: u8) bool {
        return c >= 'a' and c <= 'z';
    }

    /// `true` for a hexadecimal digit `'0'..='9' 'a'..='f' 'A'..='F'`.
    pub fn isHexDigit(c: u8) bool {
        return (c >= '0' and c <= '9') or (c >= 'a' and c <= 'f') or (c >= 'A' and c <= 'F');
    }

    /// `true` for an ASCII control byte (`0x00..=0x1F` or `0x7F`).
    pub fn isControl(c: u8) bool {
        return c < 0x20 or c == 0x7F;
    }

    /// `true` for a printable ASCII byte (space through `~`, `0x20..=0x7E`).
    pub fn isPrint(c: u8) bool {
        return c >= 0x20 and c <= 0x7E;
    }

    /// `true` for ASCII punctuation: a printable non-space, non-alphanumeric byte.
    pub fn isPunct(c: u8) bool {
        return isPrint(c) and c != ' ' and not isAlphanumeric(c);
    }

    /// The hexadecimal value `0..=15` of a hex digit, or `null` if `c` is not one.
    pub fn hexValue(c: u8) ?u8 {
        if (c >= '0' and c <= '9') return c - '0';
        if (c >= 'a' and c <= 'f') return c - 'a' + 10;
        if (c >= 'A' and c <= 'F') return c - 'A' + 10;
        return null;
    }
};

// =========================================================================
//  unicode — UTF-8 decode / validate / encode / count
// =========================================================================

/// The result of decoding one UTF-8 sequence: the codepoint, the number of bytes
/// it occupied, and whether the decode succeeded. On failure `cp`/`len` are zero
/// and `ok` is `false`.
pub const Utf8DecodeResult = struct {
    /// The decoded Unicode scalar value (valid only when `ok`).
    cp: u32,
    /// The number of bytes the sequence occupied (valid only when `ok`).
    len: usize,
    /// `true` iff a well-formed sequence was decoded.
    ok: bool,
};

/// UTF-8 utilities over `[]const u8`. Decoding rejects truncation, bad lead/
/// continuation bytes, and out-of-range codepoints; encoding writes into a
/// caller-owned `*[4]u8` (a pointer-to-array out-parameter, because a slice over a
/// stack array does not write back through the call boundary).
pub const unicode = struct {
    /// The byte length a lead byte announces: 1 (ASCII), 2, 3, or 4, or `0` for a
    /// byte that cannot start a sequence (a continuation byte or an invalid lead).
    pub fn utf8Len(first: u8) usize {
        if (first < 0x80) return 1;
        if ((first & 0xE0) == 0xC0) return 2;
        if ((first & 0xF0) == 0xE0) return 3;
        if ((first & 0xF8) == 0xF0) return 4;
        return 0;
    }

    /// Decode the sequence beginning at `s[i]`. Rejects an out-of-range index, an
    /// invalid lead byte, truncation (the sequence runs past `s.len`), a bad
    /// continuation byte (`(b & 0xC0) != 0x80`), an OVERLONG encoding (a codepoint
    /// encoded in more bytes than its minimum form), a UTF-16 SURROGATE
    /// (U+D800..U+DFFF, not a valid Unicode scalar value), and a codepoint above
    /// U+10FFFF.
    pub fn utf8DecodeAt(s: []const u8, i: usize) Utf8DecodeResult {
        if (i >= s.len) return Utf8DecodeResult{ .cp = 0, .len = 0, .ok = false };
        const b0 = s[i];
        const n = utf8Len(b0);
        if (n == 0 or i + n > s.len) return Utf8DecodeResult{ .cp = 0, .len = 0, .ok = false };
        if (n == 1) return Utf8DecodeResult{ .cp = @as(u32, b0), .len = 1, .ok = true };
        var cp: u32 = undefined;
        if (n == 2) {
            cp = @as(u32, b0 & 0x1F);
        } else if (n == 3) {
            cp = @as(u32, b0 & 0x0F);
        } else {
            cp = @as(u32, b0 & 0x07);
        }
        var k: usize = 1;
        while (k < n) : (k += 1) {
            const bx = s[i + k];
            if ((bx & 0xC0) != 0x80) return Utf8DecodeResult{ .cp = 0, .len = 0, .ok = false };
            cp = (cp << 6) | @as(u32, bx & 0x3F);
        }
        // Reject overlong forms: each length has a minimum codepoint, below which
        // the sequence is an over-long encoding of a value that fits in fewer
        // bytes (a classic security smuggling vector, e.g. an overlong `/`).
        if (n == 2 and cp < 0x80) return Utf8DecodeResult{ .cp = 0, .len = 0, .ok = false };
        if (n == 3 and cp < 0x800) return Utf8DecodeResult{ .cp = 0, .len = 0, .ok = false };
        if (n == 4 and cp < 0x10000) return Utf8DecodeResult{ .cp = 0, .len = 0, .ok = false };
        // Reject UTF-16 surrogates: U+D800..U+DFFF are not Unicode scalar values.
        if (cp >= 0xD800 and cp <= 0xDFFF) return Utf8DecodeResult{ .cp = 0, .len = 0, .ok = false };
        if (cp > 0x10FFFF) return Utf8DecodeResult{ .cp = 0, .len = 0, .ok = false };
        return Utf8DecodeResult{ .cp = cp, .len = n, .ok = true };
    }

    /// `true` iff `s` is entirely well-formed UTF-8.
    pub fn utf8Validate(s: []const u8) bool {
        var i: usize = 0;
        while (i < s.len) {
            const r = utf8DecodeAt(s, i);
            if (not r.ok) return false;
            i += r.len;
        }
        return true;
    }

    /// The number of codepoints in `s`, or `null` if `s` is not valid UTF-8.
    pub fn utf8CountCodepoints(s: []const u8) ?usize {
        var i: usize = 0;
        var n: usize = 0;
        while (i < s.len) {
            const r = utf8DecodeAt(s, i);
            if (not r.ok) return null;
            i += r.len;
            n += 1;
        }
        return n;
    }

    /// Encode codepoint `cp` into `out`, returning the number of bytes written (1
    /// to 4), or `0` if `cp` is above U+10FFFF. `out` is a pointer-to-array so the
    /// bytes are visible to the caller (a `[]u8` over a stack array would not be).
    pub fn utf8Encode(cp: u32, out: *[4]u8) usize {
        // A UTF-16 surrogate is not a valid Unicode scalar value and must not be
        // encoded (it would round-trip through the decoder as ill-formed).
        if (cp >= 0xD800 and cp <= 0xDFFF) return 0;
        if (cp < 0x80) {
            out[0] = @intCast(cp);
            return 1;
        }
        if (cp < 0x800) {
            out[0] = @intCast(0xC0 | (cp >> 6));
            out[1] = @intCast(0x80 | (cp & 0x3F));
            return 2;
        }
        if (cp < 0x10000) {
            out[0] = @intCast(0xE0 | (cp >> 12));
            out[1] = @intCast(0x80 | ((cp >> 6) & 0x3F));
            out[2] = @intCast(0x80 | (cp & 0x3F));
            return 3;
        }
        if (cp <= 0x10FFFF) {
            out[0] = @intCast(0xF0 | (cp >> 18));
            out[1] = @intCast(0x80 | ((cp >> 12) & 0x3F));
            out[2] = @intCast(0x80 | ((cp >> 6) & 0x3F));
            out[3] = @intCast(0x80 | (cp & 0x3F));
            return 4;
        }
        return 0;
    }

    /// A forward iterator over the Unicode scalar values of a UTF-8 string. Each
    /// `next` decodes the codepoint at the cursor and advances past it; an
    /// ill-formed byte sequence ends iteration (`next` returns `null`) at that
    /// position rather than yielding a replacement character.
    pub const Utf8Iterator = struct {
        s: []const u8,
        i: usize,

        /// The next codepoint, or `null` at the end (or at an ill-formed byte).
        pub fn next(self: *@This()) ?u32 {
            if (self.i >= self.s.len) return null;
            const r = utf8DecodeAt(self.s, self.i);
            if (not r.ok) return null;
            self.i += r.len;
            return r.cp;
        }
    };

    /// A `Utf8Iterator` over `s` starting at its first byte.
    pub fn iterate(s: []const u8) Utf8Iterator {
        return Utf8Iterator{ .s = s, .i = 0 };
    }
};

// =========================================================================
//  math — common numeric helpers + a fixed-width big integer
// =========================================================================

/// Pure numeric helpers. Each is a total function on concrete or comptime-`T`
/// scalars (no allocator, no `Context` — none passes a function value). The
/// width-specific forms (`absI64`) sit beside comptime-generic ones (`min`/`max`/
/// `clamp`) so both a concrete and a generic call site are served.
pub const math = struct {
    /// The lesser of `a` and `b`.
    pub fn min(comptime T: type, a: T, b: T) T {
        return if (a < b) a else b;
    }

    /// The greater of `a` and `b`.
    pub fn max(comptime T: type, a: T, b: T) T {
        return if (a > b) a else b;
    }

    /// `x` clamped into `[lo, hi]` (assumes `lo <= hi`).
    pub fn clamp(comptime T: type, x: T, lo: T, hi: T) T {
        if (x < lo) return lo;
        if (x > hi) return hi;
        return x;
    }

    /// The absolute value of a signed 64-bit integer.
    pub fn absI64(x: i64) i64 {
        return if (x < 0) -x else x;
    }

    /// The greatest common divisor of `a` and `b` (Euclid's algorithm). `gcd(0,0)`
    /// is `0`.
    pub fn gcd(a: u64, b: u64) u64 {
        var x = a;
        var y = b;
        while (y != 0) {
            const t = x % y;
            x = y;
            y = t;
        }
        return x;
    }

    /// The least common multiple of `a` and `b`; `0` if either is `0`. Computed as
    /// `a / gcd * b` to keep the intermediate small.
    pub fn lcm(a: u64, b: u64) u64 {
        if (a == 0 or b == 0) return 0;
        return (a / gcd(a, b)) * b;
    }

    /// `base` raised to `exp`, by binary exponentiation (square-and-multiply).
    /// `pow(x, 0)` is `1`.
    pub fn powU64(base: u64, exp: u64) u64 {
        var result: u64 = 1;
        var b = base;
        var e = exp;
        while (e != 0) {
            if (e & 1 == 1) result = result * b;
            e = e >> 1;
            if (e != 0) b = b * b;
        }
        return result;
    }

    /// The integer square root of `x`: the largest `r` with `r*r <= x`. A
    /// digit-by-digit (binary) method — no floating point, exact for all `u64`.
    /// `isqrt(0)` is `0`.
    pub fn isqrt(x: u64) u64 {
        var r: u64 = 0;
        // The highest power-of-four <= x (a one-bit at an even position).
        var bit: u64 = 1 << 62;
        while (bit > x) bit = bit >> 2;
        var n = x;
        while (bit != 0) {
            if (n >= r + bit) {
                n = n - (r + bit);
                r = (r >> 1) + bit;
            } else {
                r = r >> 1;
            }
            bit = bit >> 2;
        }
        return r;
    }

    /// `floor(log2(x))` — the index of the most-significant set bit. Returns `0`
    /// for `x == 0` (vacuously), matching the common `@clz`-based definition.
    pub fn log2Int(x: u64) u32 {
        if (x == 0) return 0;
        var v = x;
        var r: u32 = 0;
        while (v > 1) : (v = v >> 1) r += 1;
        return r;
    }

    /// `true` if `x` is a power of two (`1, 2, 4, …`). Zero is not.
    pub fn isPowerOfTwo(x: u64) bool {
        return x != 0 and (x & (x - 1)) == 0;
    }

    /// The number of set bits in `x` (population count, Kernighan's loop).
    pub fn popcount(x: u64) u32 {
        var v = x;
        var n: u32 = 0;
        while (v != 0) : (n += 1) v = v & (v - 1);
        return n;
    }

    /// The number of leading zero bits in a 64-bit `x` (`clz(0) == 64`).
    pub fn clz(x: u64) u32 {
        if (x == 0) return 64;
        var v = x;
        var n: u32 = 0;
        while (v & (1 << 63) == 0) : (n += 1) v = v << 1;
        return n;
    }

    /// The number of trailing zero bits in a 64-bit `x` (`ctz(0) == 64`).
    pub fn ctz(x: u64) u32 {
        if (x == 0) return 64;
        var v = x;
        var n: u32 = 0;
        while (v & 1 == 0) : (n += 1) v = v >> 1;
        return n;
    }

    /// Floor division of signed integers: rounds toward negative infinity (unlike
    /// `/`, which truncates toward zero). `divFloor(-7, 2) == -4`.
    pub fn divFloor(a: i64, b: i64) i64 {
        const q = a / b;
        const r = a % b;
        // `/` truncated toward zero; nudge down when the remainder's sign
        // disagrees with the divisor's (the true quotient was negative).
        if (r != 0 and ((r < 0) != (b < 0))) return q - 1;
        return q;
    }

    /// Euclidean modulo paired with `divFloor`, so `mod(-1, 3) == 2`. The result
    /// has the sign of `b` and lies in `[0, |b|)` for positive `b`.
    pub fn mod(a: i64, b: i64) i64 {
        const r = a % b;
        if (r != 0 and ((r < 0) != (b < 0))) return r + b;
        return r;
    }

    /// Saturating add: `a + b`, clamped to `u64`'s maximum on overflow instead of
    /// wrapping or trapping. Overflow is detected BEFORE the add (no wrapping
    /// operator and no safe-build trap).
    pub fn satAddU64(a: u64, b: u64) u64 {
        const max_u64: u64 = 0xFFFF_FFFF_FFFF_FFFF;
        if (a > max_u64 - b) return max_u64;
        return a + b;
    }

    /// Saturating subtract: `a - b`, clamped to `0` on underflow.
    pub fn satSubU64(a: u64, b: u64) u64 {
        return if (b > a) 0 else a - b;
    }

    /// The sign of a signed integer: `-1`, `0`, or `1`.
    pub fn signI64(x: i64) i64 {
        if (x > 0) return 1;
        if (x < 0) return -1;
        return 0;
    }

    /// `true` if `x` is even.
    pub fn isEven(x: i64) bool {
        return x % 2 == 0;
    }

    /// `true` if `x` is odd.
    pub fn isOdd(x: i64) bool {
        return x % 2 != 0;
    }

    /// The smallest power of two `>= x` (and `1` for `x == 0`). Returns `0` if the
    /// result would overflow `u64` (`x > 2^63`).
    pub fn nextPowerOfTwo(x: u64) u64 {
        if (x <= 1) return 1;
        if (x > (1 << 63)) return 0;
        var p: u64 = 1;
        while (p < x) p = p << 1;
        return p;
    }

    /// `n!`, by iteration. `factorial(0)` is `1`. TRAPS on overflow past `20!`
    /// (the largest factorial fitting in `u64`) in a safe build — there is no
    /// wrapping multiply, so out-of-range inputs are a checked error, not a wrap.
    pub fn factorial(n: u64) u64 {
        var r: u64 = 1;
        var i: u64 = 2;
        while (i <= n) : (i += 1) r = r * i;
        return r;
    }

    /// The `n`-th Fibonacci number (`fib(0) = 0`, `fib(1) = 1`), by iteration.
    pub fn fib(n: u64) u64 {
        var a: u64 = 0;
        var b: u64 = 1;
        var i: u64 = 0;
        while (i < n) : (i += 1) {
            const t = a + b;
            a = b;
            b = t;
        }
        return a;
    }

    /// Falling factorial / `k`-permutations of `n`: `n·(n-1)·…·(n-k+1)`. `0` if
    /// `k > n`. Overflows (traps) once the product exceeds `u64`.
    pub fn permutations(n: u64, k: u64) u64 {
        if (k > n) return 0;
        var result: u64 = 1;
        var i: u64 = 0;
        while (i < k) : (i += 1) result = result * (n - i);
        return result;
    }

    /// The binomial coefficient `C(n, k)` ("n choose k"). `0` if `k > n`. Computed
    /// incrementally (`result · (n-i) / (i+1)`, each step an exact integer) and
    /// using the symmetry `C(n,k) = C(n,n-k)` to take the smaller `k`, so it stays
    /// in `u64` for a much wider range than `n! / (k!·(n-k)!)`.
    pub fn binomial(n: u64, k: u64) u64 {
        if (k > n) return 0;
        var kk = k;
        if (kk > n - kk) kk = n - kk;
        var result: u64 = 1;
        var i: u64 = 0;
        while (i < kk) : (i += 1) {
            result = result * (n - i) / (i + 1);
        }
        return result;
    }

    /// The sum of a slice of any integer type (`0` for an empty slice).
    pub fn sumSlice(comptime T: type, xs: []const T) T {
        var s: T = 0;
        var i: usize = 0;
        while (i < xs.len) : (i += 1) s += xs[i];
        return s;
    }

    /// The largest element of a non-empty slice, or `null` if empty.
    pub fn maxSlice(comptime T: type, xs: []const T) ?T {
        if (xs.len == 0) return null;
        var m = xs[0];
        var i: usize = 1;
        while (i < xs.len) : (i += 1) {
            if (xs[i] > m) m = xs[i];
        }
        return m;
    }

    /// The smallest element of a non-empty slice, or `null` if empty.
    pub fn minSlice(comptime T: type, xs: []const T) ?T {
        if (xs.len == 0) return null;
        var m = xs[0];
        var i: usize = 1;
        while (i < xs.len) : (i += 1) {
            if (xs[i] < m) m = xs[i];
        }
        return m;
    }

    /// Primality by trial division up to `sqrt(n)`, skipping evens. The bound is
    /// `i <= n / i` (not `i*i <= n`), so the test never overflows even for a
    /// `u64`-max input. `isPrime(0)`/`isPrime(1)` are `false`.
    pub fn isPrime(n: u64) bool {
        if (n < 2) return false;
        if (n < 4) return true; // 2, 3
        if (n % 2 == 0) return false;
        var i: u64 = 3;
        while (i <= n / i) : (i += 2) {
            if (n % i == 0) return false;
        }
        return true;
    }

    /// Modular exponentiation `(base^exp) mod m`, by square-and-multiply. To keep
    /// the intermediate products from overflowing `u64`, `m` must be at most
    /// 2^32 (so every `x * y mod m` with `x, y < m` fits a `u64`). `modPow(_, 0, m)`
    /// is `1 mod m`; `m == 0` returns `0`.
    pub fn modPow(base: u64, exp: u64, m: u64) u64 {
        if (m == 0) return 0;
        if (m == 1) return 0;
        var result: u64 = 1;
        var b = base % m;
        var e = exp;
        while (e != 0) {
            if (e & 1 == 1) result = (result * b) % m;
            e = e >> 1;
            if (e != 0) b = (b * b) % m;
        }
        return result;
    }

    /// Ceiling division `ceil(a / b)` for unsigned integers (`b != 0`). Computed as
    /// `a / b + (a % b != 0)` so it never overflows. `divCeil(7, 3)` is `3`.
    pub fn divCeil(a: u64, b: u64) u64 {
        const q = a / b;
        if (a % b != 0) return q + 1;
        return q;
    }

    /// Round `x` UP to the nearest multiple of `m` (`m != 0`). Already-multiples are
    /// unchanged. `roundUpToMultiple(13, 8)` is `16`.
    pub fn roundUpToMultiple(x: u64, m: u64) u64 {
        return divCeil(x, m) * m;
    }

    /// Round `x` DOWN to the nearest multiple of `m` (`m != 0`).
    pub fn roundDownToMultiple(x: u64, m: u64) u64 {
        return (x / m) * m;
    }

    /// Round `x` UP to the nearest multiple of `alignment`, which MUST be a power of
    /// two — the fast bit-twiddling form of `roundUpToMultiple`. A non-power-of-two
    /// `alignment` gives an unspecified result.
    pub fn alignForward(x: u64, alignment: u64) u64 {
        return (x + (alignment - 1)) & ~(alignment - 1);
    }

    /// The sum of the decimal digits of `n` (`digitSum(0)` is `0`).
    pub fn digitSum(n: u64) u64 {
        var v = n;
        var s: u64 = 0;
        while (v != 0) {
            s += v % 10;
            v = v / 10;
        }
        return s;
    }

    /// The number of decimal digits of `n` (`digitCount(0)` is `1`).
    pub fn digitCount(n: u64) u64 {
        if (n == 0) return 1;
        var v = n;
        var c: u64 = 0;
        while (v != 0) : (v = v / 10) c += 1;
        return c;
    }

    /// `n` with its decimal digits reversed (`reverseDigits(1230)` is `321`), or
    /// `null` if the reversal would overflow `u64`. Trailing zeros are dropped.
    pub fn reverseDigits(n: u64) ?u64 {
        const max_u64: u64 = 0xFFFF_FFFF_FFFF_FFFF;
        var v = n;
        var r: u64 = 0;
        while (v != 0) {
            const d = v % 10;
            if (r > (max_u64 - d) / 10) return null; // would overflow
            r = r * 10 + d;
            v = v / 10;
        }
        return r;
    }

    /// `true` if `n` reads the same forwards and backwards in base 10.
    pub fn isPalindrome(n: u64) bool {
        const rev = reverseDigits(n);
        if (rev == null) return false;
        return rev.? == n;
    }
};

// =========================================================================
//  mathf — floating-point (`f64`) math by numerical approximation
// =========================================================================

/// Floating-point helpers computed from scratch (no hardware transcendental
/// instructions): square root by Newton's method, rounding via the integer
/// conversion builtins, and `exp`/`ln`/`sin`/`cos` by range-reduced series. Inputs
/// are assumed finite and within roughly `|x| < 2^52` where an integer conversion
/// is involved; accuracy is ~1e-12 for the elementary functions.
pub const mathf = struct {
    /// The ratio of a circle's circumference to its diameter.
    pub const pi: f64 = 3.141592653589793;
    /// Euler's number.
    pub const e: f64 = 2.718281828459045;

    /// The absolute value of `x`.
    pub fn abs(x: f64) f64 {
        return if (x < 0.0) -x else x;
    }

    /// The square root of `x` (Newton–Raphson). `sqrt(x)` for `x <= 0` is `0`.
    /// `x` is first scaled by powers of four into `[1, 4)`, so Newton starts near
    /// the answer and a handful of iterations suffice for ANY magnitude (a plain
    /// `g = x` start needs O(log x) iterations and fails past ~1e33).
    pub fn sqrt(x: f64) f64 {
        if (x <= 0.0) return 0.0;
        // x = m · 4^k with m ∈ [1, 4); then sqrt(x) = sqrt(m) · 2^k.
        var m = x;
        var k: i64 = 0;
        while (m >= 4.0) {
            m = m / 4.0;
            k += 1;
        }
        while (m < 1.0) {
            m = m * 4.0;
            k -= 1;
        }
        var g = m;
        var i: u32 = 0;
        while (i < 30) : (i += 1) {
            const next = 0.5 * (g + m / g);
            if (abs(next - g) <= 1e-15 * next) {
                g = next;
                break;
            }
            g = next;
        }
        if (k >= 0) return g * powi(2.0, @as(u64, @intCast(k)));
        return g / powi(2.0, @as(u64, @intCast(-k)));
    }

    /// The largest integer value `<= x`, as an `f64`.
    pub fn floor(x: f64) f64 {
        const t = @as(f64, @floatFromInt(@as(i64, @intFromFloat(x))));
        if (t > x) return t - 1.0;
        return t;
    }

    /// The smallest integer value `>= x`, as an `f64`.
    pub fn ceil(x: f64) f64 {
        const t = @as(f64, @floatFromInt(@as(i64, @intFromFloat(x))));
        if (t < x) return t + 1.0;
        return t;
    }

    /// `x` rounded to the nearest integer (ties away from zero), as an `f64`.
    /// Compares the residual `x - floor(x)` against `0.5` rather than forming
    /// `floor(x + 0.5)` — the latter double-rounds `0.49999999999999994` up to `1`.
    pub fn round(x: f64) f64 {
        if (x < 0.0) return -round(-x);
        const r = floor(x);
        if (x - r >= 0.5) return r + 1.0;
        return r;
    }

    /// The fractional part of `x` (`x - trunc(x)`), keeping `x`'s sign.
    pub fn fract(x: f64) f64 {
        const t = @as(f64, @floatFromInt(@as(i64, @intFromFloat(x))));
        return x - t;
    }

    /// `base` raised to a non-negative INTEGER power `n`, by binary exponentiation.
    pub fn powi(base: f64, n: u64) f64 {
        var result: f64 = 1.0;
        var b = base;
        var e2 = n;
        while (e2 != 0) {
            if (e2 & 1 == 1) result = result * b;
            e2 = e2 >> 1;
            if (e2 != 0) b = b * b;
        }
        return result;
    }

    /// `e^x` by the Taylor series, after reducing `x` by its integer part so the
    /// series converges fast: `e^x = e^k * e^f` with `k = round(x)`, `|f| <= 0.5`.
    pub fn exp(x: f64) f64 {
        const k = round(x);
        const f = x - k;
        // e^f via Taylor (|f| <= 0.5 converges in ~12 terms).
        var term: f64 = 1.0;
        var sum: f64 = 1.0;
        var i: u32 = 1;
        while (i < 18) : (i += 1) {
            term = term * f / @as(f64, @floatFromInt(@as(i64, @intCast(i))));
            sum = sum + term;
        }
        // e^k by integer power of e (or 1/e for negative k).
        const ki = @as(i64, @intFromFloat(k));
        if (ki >= 0) return sum * powi(e, @as(u64, @intCast(ki)));
        return sum / powi(e, @as(u64, @intCast(-ki)));
    }

    /// Reduce an angle to `[-pi, pi]` by subtracting whole turns.
    fn reduceAngle(x: f64) f64 {
        const two_pi = 2.0 * pi;
        const turns = round(x / two_pi);
        return x - turns * two_pi;
    }

    /// `sin(x)` (radians) by the range-reduced Taylor series.
    pub fn sin(x: f64) f64 {
        const a = reduceAngle(x);
        var term = a;
        var sum = a;
        const a2 = a * a;
        var i: u32 = 1;
        while (i < 12) : (i += 1) {
            const d1 = @as(f64, @floatFromInt(@as(i64, @intCast(2 * i))));
            const d2 = @as(f64, @floatFromInt(@as(i64, @intCast(2 * i + 1))));
            term = -term * a2 / (d1 * d2);
            sum = sum + term;
        }
        return sum;
    }

    /// `cos(x)` (radians) by the range-reduced Taylor series.
    pub fn cos(x: f64) f64 {
        const a = reduceAngle(x);
        var term: f64 = 1.0;
        var sum: f64 = 1.0;
        const a2 = a * a;
        var i: u32 = 1;
        // 13 terms (vs sin's 12): the highest cos term is `a^22/22!`, so near `±pi`
        // an extra term is needed to stay under ~1e-12.
        while (i < 13) : (i += 1) {
            const d1 = @as(f64, @floatFromInt(@as(i64, @intCast(2 * i - 1))));
            const d2 = @as(f64, @floatFromInt(@as(i64, @intCast(2 * i))));
            term = -term * a2 / (d1 * d2);
            sum = sum + term;
        }
        return sum;
    }

    /// The Euclidean hypotenuse `sqrt(a^2 + b^2)`, scaled by the larger magnitude so
    /// it neither overflows nor underflows when the true result is representable
    /// (`hypot(1e200, 1e200)` is finite, not `inf`/`NaN`).
    pub fn hypot(a: f64, b: f64) f64 {
        const aa = abs(a);
        const ab = abs(b);
        const m = if (aa > ab) aa else ab;
        if (m == 0.0) return 0.0;
        const x = a / m;
        const y = b / m;
        return m * sqrt(x * x + y * y);
    }

    /// `tan(x)` (radians) as `sin(x) / cos(x)`. Near an odd multiple of `pi/2` the
    /// cosine approaches zero and the result blows up, as expected.
    pub fn tan(x: f64) f64 {
        return sin(x) / cos(x);
    }

    /// The natural logarithm `ln(x)` for `x > 0` (`0` for `x <= 0`). Reduces `x`
    /// into `[~0.6, 1.5]` by factoring out powers of `e`, then sums the `atanh`
    /// series `ln(v) = 2·(z + z³/3 + z⁵/5 + …)` with `z = (v-1)/(v+1)`.
    pub fn ln(x: f64) f64 {
        if (x <= 0.0) return 0.0;
        var v = x;
        var k: f64 = 0.0;
        while (v > 1.5) {
            v = v / e;
            k += 1.0;
        }
        while (v < 0.6) {
            v = v * e;
            k -= 1.0;
        }
        const z = (v - 1.0) / (v + 1.0);
        const z2 = z * z;
        var term = z;
        var sum = z;
        var i: u32 = 1;
        while (i < 24) : (i += 1) {
            term = term * z2;
            sum = sum + term / @as(f64, @floatFromInt(@as(i64, @intCast(2 * i + 1))));
        }
        return k + 2.0 * sum;
    }

    /// The base-`b` logarithm of `x` (`x, b > 0`, `b != 1`).
    pub fn logBase(x: f64, b: f64) f64 {
        return ln(x) / ln(b);
    }

    /// General power `base^exponent` for a POSITIVE base, via `exp(exponent ·
    /// ln(base))`. (Use `powi` for an integer exponent of any base.)
    pub fn pow(base: f64, exponent: f64) f64 {
        if (base <= 0.0) return 0.0;
        return exp(exponent * ln(base));
    }

    /// Base-10 logarithm (`x > 0`).
    pub fn log10(x: f64) f64 {
        return ln(x) / ln(10.0);
    }

    /// Base-2 logarithm (`x > 0`).
    pub fn log2(x: f64) f64 {
        return ln(x) / ln(2.0);
    }

    /// The real cube root of `x` (handles negatives, unlike `pow`).
    pub fn cbrt(x: f64) f64 {
        if (x == 0.0) return 0.0;
        if (x < 0.0) return -pow(-x, 1.0 / 3.0);
        return pow(x, 1.0 / 3.0);
    }

    /// Truncate `x` toward zero, as an `f64` (drops the fractional part).
    pub fn trunc(x: f64) f64 {
        return @as(f64, @floatFromInt(@as(i64, @intFromFloat(x))));
    }

    /// `-1.0`, `0.0`, or `1.0` for the sign of `x`.
    pub fn signf(x: f64) f64 {
        if (x > 0.0) return 1.0;
        if (x < 0.0) return -1.0;
        return 0.0;
    }

    /// The lesser of `a` and `b`.
    pub fn minf(a: f64, b: f64) f64 {
        return if (a < b) a else b;
    }

    /// The greater of `a` and `b`.
    pub fn maxf(a: f64, b: f64) f64 {
        return if (a > b) a else b;
    }

    /// `x` clamped into `[lo, hi]` (assumes `lo <= hi`).
    pub fn clampf(x: f64, lo: f64, hi: f64) f64 {
        if (x < lo) return lo;
        if (x > hi) return hi;
        return x;
    }

    /// Linear interpolation between `a` and `b` by `t` (`lerp(a,b,0)=a`,
    /// `lerp(a,b,1)=b`; `t` outside `[0,1]` extrapolates).
    pub fn lerp(a: f64, b: f64, t: f64) f64 {
        return a + (b - a) * t;
    }

    /// Convert degrees to radians.
    pub fn degToRad(deg: f64) f64 {
        return deg * (pi / 180.0);
    }

    /// Convert radians to degrees.
    pub fn radToDeg(rad: f64) f64 {
        return rad * (180.0 / pi);
    }

    /// Arctangent of `x`, in `(-pi/2, pi/2)`. Reflects `x > 1` through
    /// `atan(x) = pi/2 - atan(1/x)`, then shrinks the argument with the half-angle
    /// identity `atan(v) = 2·atan(v/(1+sqrt(1+v²)))` until it is small, where the
    /// power series converges fast (the raw series at `x = 1` converges like `1/n`
    /// and would need millions of terms).
    pub fn atan(x: f64) f64 {
        if (x < 0.0) return -atan(-x);
        if (x > 1.0) return (pi / 2.0) - atan(1.0 / x);
        // Halve the argument until `v <= 0.2`, doubling once per reduction.
        var v = x;
        var reductions: u32 = 0;
        while (v > 0.2) {
            v = v / (1.0 + sqrt(1.0 + v * v));
            reductions += 1;
        }
        const v2 = v * v;
        var term = v;
        var sum = v;
        var i: u32 = 1;
        while (i < 24) : (i += 1) {
            term = -term * v2;
            const denom = @as(f64, @floatFromInt(@as(i64, @intCast(2 * i + 1))));
            sum = sum + term / denom;
        }
        var k: u32 = 0;
        while (k < reductions) : (k += 1) sum = sum * 2.0;
        return sum;
    }
};

// =========================================================================
//  bits — unsigned bit manipulation (byte swap, rotate, single-bit ops)
// =========================================================================

/// Pure bit-twiddling over fixed-width unsigned integers. Single-bit indices and
/// rotate/shift amounts are `u6` (`0..=63`) for the `u64` operations, matching the
/// width so a shift never exceeds it.
pub const bits = struct {
    /// Reverse the two bytes of a `u16`.
    pub fn byteSwap16(x: u16) u16 {
        return ((x & 0x00FF) << 8) | ((x >> 8) & 0x00FF);
    }

    /// Reverse the four bytes of a `u32`.
    pub fn byteSwap32(x: u32) u32 {
        return ((x & 0x0000_00FF) << 24) | ((x & 0x0000_FF00) << 8) |
            ((x >> 8) & 0x0000_FF00) | ((x >> 24) & 0x0000_00FF);
    }

    /// Reverse the eight bytes of a `u64`.
    pub fn byteSwap64(x: u64) u64 {
        var r: u64 = 0;
        var i: u6 = 0;
        while (i < 8) : (i += 1) {
            const byte = (x >> (@as(u6, i) * 8)) & 0xFF;
            r = r | (byte << ((7 - @as(u6, i)) * 8));
        }
        return r;
    }

    /// Rotate the bits of a `u64` LEFT by `n` (`0..=63`).
    pub fn rotateLeft64(x: u64, n: u6) u64 {
        if (n == 0) return x;
        return (x << n) | (x >> (64 - @as(u32, n)));
    }

    /// Rotate the bits of a `u64` RIGHT by `n` (`0..=63`).
    pub fn rotateRight64(x: u64, n: u6) u64 {
        if (n == 0) return x;
        return (x >> n) | (x << (64 - @as(u32, n)));
    }

    /// `x` with bit `i` set.
    pub fn setBit(x: u64, i: u6) u64 {
        return x | (@as(u64, 1) << i);
    }

    /// `x` with bit `i` cleared.
    pub fn clearBit(x: u64, i: u6) u64 {
        return x & ~(@as(u64, 1) << i);
    }

    /// `x` with bit `i` flipped.
    pub fn toggleBit(x: u64, i: u6) u64 {
        return x ^ (@as(u64, 1) << i);
    }

    /// `true` if bit `i` of `x` is set.
    pub fn testBit(x: u64, i: u6) bool {
        return (x >> i) & 1 == 1;
    }

    /// The reverse of all 64 bits of `x` (bit 0 ↔ bit 63, …).
    pub fn reverseBits64(x: u64) u64 {
        var r: u64 = 0;
        var i: u6 = 0;
        var k: u32 = 0;
        while (k < 64) : (k += 1) {
            r = (r << 1) | ((x >> @as(u6, i)) & 1);
            if (i < 63) i += 1;
        }
        return r;
    }
};

/// A fixed-width 256-bit unsigned big integer: eight little-endian 32-bit limbs.
/// Beyond `u128`, with `add`/`sub`/`mul`/`cmp`/`toDecimal`. Every limb operation
/// is done in `u64` and masked back to 32 bits so no intermediate can overflow a
/// `u64` (and thus never traps in a safe build). This is the fixed-precision form;
/// arbitrary precision would back the limbs with a heap slice.
pub const Big = struct {
    const Self = @This();

    /// The eight little-endian 32-bit limbs (`limbs[0]` is least significant).
    limbs: [8]u32,

    /// The big integer `0`.
    pub fn zero() Self {
        return Self{ .limbs = [8]u32{ 0, 0, 0, 0, 0, 0, 0, 0 } };
    }

    /// The big integer equal to a `u64` (occupies the low two limbs).
    pub fn fromU64(v: u64) Self {
        var b = zero();
        const m: u64 = 0xFFFFFFFF;
        b.limbs[0] = @intCast(v & m);
        b.limbs[1] = @intCast((v >> 32) & m);
        return b;
    }

    /// `a + b`, wrapping (mod 2^256) on overflow past the top limb.
    pub fn add(a: Self, b: Self) Self {
        var r = zero();
        const m: u64 = 0xFFFFFFFF;
        var carry: u64 = 0;
        var i: usize = 0;
        while (i < 8) : (i += 1) {
            const s: u64 = @as(u64, a.limbs[i]) + @as(u64, b.limbs[i]) + carry;
            r.limbs[i] = @intCast(s & m);
            carry = s >> 32;
        }
        return r;
    }

    /// `a - b`, wrapping (mod 2^256) if `b > a`.
    pub fn sub(a: Self, b: Self) Self {
        var r = zero();
        const m: u64 = 0xFFFFFFFF;
        const base: u64 = 0x100000000;
        var borrow: u64 = 0;
        var i: usize = 0;
        while (i < 8) : (i += 1) {
            const ai: u64 = @as(u64, a.limbs[i]);
            const bi: u64 = @as(u64, b.limbs[i]) + borrow;
            if (ai >= bi) {
                r.limbs[i] = @intCast((ai - bi) & m);
                borrow = 0;
            } else {
                r.limbs[i] = @intCast((ai + base - bi) & m);
                borrow = 1;
            }
        }
        return r;
    }

    /// `a * b`, schoolbook, truncated to 256 bits. Each partial product is a
    /// `u32 * u32` in `u64` plus carries, masked to 32 bits per limb.
    pub fn mul(a: Self, b: Self) Self {
        var r = zero();
        const m: u64 = 0xFFFFFFFF;
        var i: usize = 0;
        while (i < 8) : (i += 1) {
            var carry: u64 = 0;
            var j: usize = 0;
            while (i + j < 8) : (j += 1) {
                const idx = i + j;
                const cur: u64 = @as(u64, r.limbs[idx]) +
                    @as(u64, a.limbs[i]) * @as(u64, b.limbs[j]) + carry;
                r.limbs[idx] = @intCast(cur & m);
                carry = cur >> 32;
            }
        }
        return r;
    }

    /// `-1` if `a < b`, `0` if equal, `1` if `a > b` (compares from the top limb).
    pub fn cmp(a: Self, b: Self) i32 {
        var i: usize = 8;
        while (i > 0) {
            i -= 1;
            if (a.limbs[i] < b.limbs[i]) return -1;
            if (a.limbs[i] > b.limbs[i]) return 1;
        }
        return 0;
    }

    /// `true` if the value is zero.
    pub fn isZero(a: Self) bool {
        var i: usize = 0;
        while (i < 8) : (i += 1) {
            if (a.limbs[i] != 0) return false;
        }
        return true;
    }

    /// Divide `a` in place by a small `u32` divisor, returning the remainder. Used
    /// by `toDecimal` to peel off base-10 digits.
    fn divSmall(a: *Self, d: u32) u32 {
        const m: u64 = 0xFFFFFFFF;
        var rem: u64 = 0;
        var i: usize = 8;
        while (i > 0) {
            i -= 1;
            const cur: u64 = (rem << 32) | @as(u64, a.limbs[i]);
            a.limbs[i] = @intCast((cur / @as(u64, d)) & m);
            rem = cur % @as(u64, d);
        }
        return @intCast(rem);
    }

    /// Render the value as a base-10 string into the caller's `buf`, returning the
    /// written prefix. `buf` must be large enough (80 bytes covers 256 bits). The
    /// digits are produced least-significant-first by repeated `divSmall(10)`,
    /// then reversed in place.
    pub fn toDecimal(a: Self, buf: []u8) []u8 {
        var tmp = a;
        if (isZero(tmp)) {
            buf[0] = '0';
            return buf[0..1];
        }
        var n: usize = 0;
        while (not isZero(tmp)) {
            const dig = divSmall(&tmp, 10);
            buf[n] = @intCast(@as(u32, '0') + dig);
            n += 1;
        }
        var i: usize = 0;
        var j: usize = n - 1;
        while (i < j) {
            const t = buf[i];
            buf[i] = buf[j];
            buf[j] = t;
            i += 1;
            j -= 1;
        }
        return buf[0..n];
    }
};

// =========================================================================
//  testing — assertions + a leak-detecting testing allocator
// =========================================================================

/// Test helpers. Assertions are VALUES: a failing `expect*` returns an error,
/// so a test runner reports it as an ordinary failure (no exceptions).
pub const testing = struct {
    /// A leak-detecting allocator handed to each test. It is a GPA-tracked
    /// handle; the test harness checks it at test end and fails on a leak.
    pub const allocator: Allocator = @allocHandle(@allocId(5, 0));

    /// Succeed iff `ok` is true. On failure records a clear message for the runner
    /// ("expect failed: condition was false") and returns the test error.
    pub fn expect(ok: bool) !void {
        if (not ok) {
            @testFail("expect", "condition was false");
            return error.TestUnexpectedResult;
        }
    }

    /// Succeed iff `expected == actual`. On mismatch records the rich
    /// "expected X, found Y" message (formatted by the VM value formatter) so the
    /// runner can show exactly what differed.
    pub fn expectEqual(expected: anytype, actual: anytype) !void {
        if (expected != actual) {
            @testFailEq(expected, actual);
            return error.TestExpectedEqual;
        }
    }

    /// Succeed iff `actual` is the error `expected` (and not a success value).
    pub fn expectError(expected: anyerror, actual: anytype) !void {
        if (actual) |_| {
            @testFail("expectError", "expected an error, found a value");
            return error.TestExpectedError;
        } else |e| {
            if (e != expected) {
                @testFailErr(expected, e);
                return error.TestUnexpectedError;
            }
        }
    }

    /// Succeed iff two slices are element-wise equal. On mismatch records the ACTUAL
    /// divergence: a "lengths differ: N vs M" message when the lengths differ, else
    /// "slices differ at index I: expected X, found Y" naming the first differing
    /// element — never the misleading "expected N, found N" (the two lengths) that a
    /// bare length comparison produced on an equal-length-but-differing pair.
    pub fn expectEqualSlices(comptime T: type, a: []const T, b: []const T) !void {
        if (not mem.eql(T, a, b)) {
            @testFailSlice(a, b);
            return error.TestExpectedEqual;
        }
    }

    /// Succeed iff two byte strings are equal (a `[]const u8` specialization of
    /// `expectEqualSlices`). On mismatch the runner shows the quoted bytes.
    pub fn expectEqualStrings(a: []const u8, b: []const u8) !void {
        if (not mem.eql(u8, a, b)) {
            @testFailEq(a, b);
            return error.TestExpectedEqual;
        }
    }

    /// Draw the next deterministic pseudo-random `u64` fuzz input from the
    /// fixed-seed PRNG. Use it inside a `test "fuzz: ..."` block, then call the
    /// function under test DIRECTLY on the value, and run with `k2c test --fuzz`:
    /// the runner re-runs the block on N inputs (`--fuzz-runs`), re-seeding per
    /// iteration from `--seed`, and reports the first failing input + iteration so
    /// a planted bug is reproducible. A direct call is used (not a function value)
    /// because the MIR has no indirect calls; the runner supplies the loop.
    ///
    /// PROBABILISTIC, not exhaustive. Fuzzing samples the input space; for a given
    /// `--seed` the run is fully deterministic and reproducible, but whether a bug is
    /// FOUND depends on the seed and on `--fuzz-runs` exceeding ~1/p, where p is the
    /// probability a random input triggers the bug. A bug that fires on a single
    /// specific byte (p ≈ 1/256) can be MISSED at `--fuzz-runs=256` under an unlucky
    /// seed (~37% miss rate, the coupon-collector tail), reading as a false PASS.
    /// For a deterministic regression set `--fuzz-runs` well above 1/p (or test the
    /// trigger directly); a passing fuzz run means "no failure in N samples", not
    /// "proven correct".
    ///
    /// ```
    /// test "fuzz: parse never traps" {
    ///     const x = std.testing.fuzzInput();
    ///     try parse(x);            // a direct call — the runner drives the loop
    /// }
    /// ```
    pub fn fuzzInput() u64 {
        return @fuzzNextU64();
    }
};

// =========================================================================
//  fmt — formatting helpers shared with the io print path
// =========================================================================

/// Formatting helpers. `bufPrint` formats into a caller buffer, sharing the
/// exact engine the `Writer.print` io path uses (the VM's `@bufPrint`/`@print`).
pub const fmt = struct {
    /// Format `args` into `buf` per `template`, returning the written prefix or
    /// `error.NoSpaceLeft` if it does not fit.
    pub fn bufPrint(buf: []u8, comptime template: []const u8, args: anytype) ![]u8 {
        return @bufPrint(buf, template, args);
    }

    /// Parse an unsigned decimal string to a `u64`. `null` on an empty string, a
    /// non-digit byte, or overflow. Overflow is checked BEFORE each multiply, so it
    /// never traps. Leading zeros are accepted (`"007"` is `7`).
    pub fn parseUint(s: []const u8) ?u64 {
        if (s.len == 0) return null;
        const max_u64: u64 = 0xFFFF_FFFF_FFFF_FFFF;
        var acc: u64 = 0;
        var i: usize = 0;
        while (i < s.len) : (i += 1) {
            const c = s[i];
            if (c < '0' or c > '9') return null;
            const d: u64 = @as(u64, c - '0');
            if (acc > (max_u64 - d) / 10) return null; // would overflow
            acc = acc * 10 + d;
        }
        return acc;
    }

    /// Parse a signed decimal string (optional leading `+`/`-`) to an `i64`. `null`
    /// on a malformed string or a value outside `i64`. Supports the full range
    /// including `i64`'s minimum.
    pub fn parseInt(s: []const u8) ?i64 {
        if (s.len == 0) return null;
        var neg = false;
        var body = s;
        if (s[0] == '-') {
            neg = true;
            body = s[1..s.len];
        } else if (s[0] == '+') {
            body = s[1..s.len];
        }
        const u_opt = parseUint(body);
        if (u_opt == null) return null;
        const u = u_opt.?;
        const i64_min_mag: u64 = 0x8000_0000_0000_0000; // |i64::MIN|
        const i64_max: u64 = 0x7FFF_FFFF_FFFF_FFFF;
        if (neg) {
            if (u == i64_min_mag) return -9223372036854775807 - 1; // i64::MIN
            if (u > i64_min_mag) return null;
            return -@as(i64, @intCast(u));
        }
        if (u > i64_max) return null;
        return @as(i64, @intCast(u));
    }

    /// The 0..=35 value of a base-36 alphanumeric digit (`0-9 a-z A-Z`), or `null`.
    fn digitValue(c: u8) ?u8 {
        if (c >= '0' and c <= '9') return c - '0';
        if (c >= 'a' and c <= 'z') return c - 'a' + 10;
        if (c >= 'A' and c <= 'Z') return c - 'A' + 10;
        return null;
    }

    /// Parse an unsigned string in `radix` (2..=36) to a `u64`. `null` on an empty
    /// string, a digit out of range for the radix, or overflow.
    pub fn parseUintRadix(s: []const u8, radix: u8) ?u64 {
        if (s.len == 0 or radix < 2 or radix > 36) return null;
        const max_u64: u64 = 0xFFFF_FFFF_FFFF_FFFF;
        const r: u64 = @as(u64, radix);
        var acc: u64 = 0;
        var i: usize = 0;
        while (i < s.len) : (i += 1) {
            const dv_opt = digitValue(s[i]);
            if (dv_opt == null) return null;
            const dv = dv_opt.?;
            if (dv >= radix) return null;
            const d: u64 = @as(u64, dv);
            if (acc > (max_u64 - d) / r) return null;
            acc = acc * r + d;
        }
        return acc;
    }

    const lower_digits = "0123456789abcdefghijklmnopqrstuvwxyz";

    /// Write `value` in `radix` (2..=36, lowercase) into `buf` and return the
    /// written sub-slice. `buf` needs at most 64 bytes (a `u64` in base 2). An
    /// out-of-range radix writes nothing (returns an empty slice).
    pub fn formatUintRadix(buf: []u8, value: u64, radix: u8) []u8 {
        if (radix < 2 or radix > 36) return buf[0..0];
        if (value == 0) {
            buf[0] = '0';
            return buf[0..1];
        }
        // Emit least-significant digit first into a scratch array, then reverse.
        var tmp: [64]u8 = undefined;
        const r: u64 = @as(u64, radix);
        var n = value;
        var i: usize = 0;
        while (n > 0) {
            tmp[i] = lower_digits[@as(usize, @intCast(n % r))];
            n = n / r;
            i += 1;
        }
        var j: usize = 0;
        while (j < i) : (j += 1) buf[j] = tmp[i - 1 - j];
        return buf[0..i];
    }

    /// Write `value` as decimal into `buf` (a leading `-` for negatives) and return
    /// the written sub-slice. `buf` needs at most 20 bytes.
    pub fn formatInt(buf: []u8, value: i64) []u8 {
        if (value < 0) {
            buf[0] = '-';
            // Negate into u64 to cover i64::MIN without overflow.
            const mag: u64 = if (value == -9223372036854775807 - 1)
                0x8000_0000_0000_0000
            else
                @as(u64, @intCast(-value));
            const body = formatUintRadix(buf[1 .. buf.len], mag, 10);
            return buf[0 .. 1 + body.len];
        }
        return formatUintRadix(buf, @as(u64, @intCast(value)), 10);
    }
};

// =========================================================================
//  Thread — the Executor capability + Task handle + sync primitives
// =========================================================================
//
// CONCURRENCY MODEL (v0.11). The VM realizes the spec's colorless async /
// `Executor` API with a DETERMINISTIC COOPERATIVE FIBER SCHEDULER: each spawned
// unit of work is a green fiber with its own call stack, and a single-threaded
// event loop interleaves ready fibers at explicit yield points (spawn / channel
// send-recv / mutex acquire / await / yield). Output is reproducible because the
// scheduler is a FIFO state machine. NONE of these objects is global: an
// `Executor`/`Loop` is a value built from `sys.heap` and passed explicitly,
// exactly as `ArrayList` is. OS-thread parallelism and the stackless async
// lowering are the NATIVE-backend (post-0.13) realization of the SAME API; the
// VM realizes it via fibers. See `crates/k2-vm/src/sched.rs`.

/// The thread / executor namespace: the spawning capability and the cooperative
/// synchronization primitives, every one an explicit value (never a global).
pub const Thread = struct {
    /// The thread-pool / executor capability. Built from the heap capability
    /// (charter: visible authority). Under the VM it drives fibers; native
    /// codegen maps it to OS threads. `spawn(work, args)` returns a `Task`.
    pub const Executor = struct {
        const Self = @This();
        /// The allocator the executor was built over (its visible authority).
        alloc: Allocator,

        /// Executor configuration: how many workers to (virtually) run.
        pub const Config = struct {
            /// Worker count. Virtual under the cooperative fiber scheduler.
            worker_count: u32 = 1,
        };

        /// Construct the executor over the heap capability — the visible point at
        /// which spawning authority enters the program.
        pub fn init(alloc: Allocator, cfg: Config) Self {
            _ = cfg;
            return Self{ .alloc = alloc };
        }

        /// Tear down. Tasks are joined explicitly via `Task.join`, so this is a
        /// no-op for the fiber realization (no OS threads to join).
        pub fn deinit(self: *Self) void {
            _ = self;
        }

        /// Spawn `work(args...)` as a fiber; return its `Task` handle. `work` is a
        /// function and `args` an argument tuple copied into the task's frame. The
        /// lowerer rewrites this call to the `@schedSpawn` scheduler intrinsic with
        /// `work` resolved to its function reference (colorless: any fn can be
        /// spawned).
        pub fn spawn(self: *Self, work: anytype, args: anytype) Task {
            _ = self;
            return Task{ .id = @schedSpawn(work, args) };
        }

        /// Drain all spawned work cooperatively (the spec's `waitIdle`): drives the
        /// scheduler to quiescence, returning only once no fiber is still runnable.
        /// `@schedRun` re-enters the ready set each round (yielding to every ready
        /// fiber, including descendants spawned mid-drain and joiners woken as work
        /// completes) until the ready queue is empty — so every transitively
        /// reachable task has run to completion before this returns. A fiber left
        /// permanently blocked with no waker is a deadlock, reported cleanly by the
        /// event loop rather than spun on.
        pub fn waitIdle(self: *Self) void {
            _ = self;
            @schedRun();
        }
    };

    /// A spawned task / future handle. `join` blocks the current fiber until the
    /// task completes; `result(T)` additionally yields its value.
    pub const Task = struct {
        const Self = @This();
        /// The VM-side fiber id.
        id: u32,

        /// Block until the task completes (its result is discarded).
        pub fn join(self: Self) void {
            _ = @schedAwait(self.id);
        }

        /// Block until the task completes and yield its `T` result.
        pub fn result(self: Self, comptime T: type) T {
            return @schedAwait(self.id);
        }
    };

    /// A cooperative mutex. A fiber holding the lock that yields keeps it; other
    /// fibers `lock` block (FIFO) until `unlock` hands it over. Pair `lock()` with
    /// `defer unlock()` — the same explicit-cleanup discipline as allocations.
    pub const Mutex = struct {
        const Self = @This();
        /// The VM-side mutex id. Construct with `Mutex.init()` (the cooperative
        /// fiber realization needs a registered cell, so the id is not defaulted).
        id: u32,

        /// Construct a fresh, unheld mutex.
        pub fn init() Self {
            return Self{ .id = @mutexMake() };
        }

        /// Acquire the lock, blocking the current fiber while it is held elsewhere.
        pub fn lock(self: *Self) void {
            @mutexLock(self.id);
        }

        /// Release the lock, handing it to the first waiter (if any).
        pub fn unlock(self: *Self) void {
            @mutexUnlock(self.id);
        }
    };

    /// A wait-group: the structured-concurrency join primitive. `add(n)` raises
    /// the outstanding count, `done()` lowers it, and `wait()` blocks until zero.
    pub const WaitGroup = struct {
        const Self = @This();
        /// The VM-side wait-group id. Construct with `WaitGroup.init()`.
        id: u32,

        /// Construct a fresh wait-group with a zero counter.
        pub fn init() Self {
            return Self{ .id = @wgMake() };
        }

        /// Add `n` to the outstanding count.
        pub fn add(self: *Self, n: u32) void {
            @wgAdd(self.id, n);
        }

        /// Mark one unit of work done; wakes waiters when the count reaches zero.
        pub fn done(self: *Self) void {
            @wgDone(self.id);
        }

        /// Block the current fiber until the count reaches zero.
        pub fn wait(self: *Self) void {
            @wgWait(self.id);
        }
    };

    /// Cooperatively yield the current fiber to the scheduler.
    pub fn yieldNow() void {
        @schedYield();
    }
};

// =========================================================================
//  Channel(T) — a bounded/unbounded mpsc for fiber communication
// =========================================================================

/// A first-in-first-out channel of `T` for fiber communication. `send` may block
/// (yield) when a bounded channel is full; `recv` blocks until a value arrives or
/// the channel is closed and drained. It is an ordinary generic — a comptime
/// function from a type to a type — and a value you pass explicitly.
pub fn Channel(comptime T: type) type {
    return struct {
        const Self = @This();
        /// The VM-side channel id.
        id: u32,

        /// Construct a channel. `cap == 0` is unbounded; `cap > 0` bounds the
        /// buffer to `cap` values (so a producer outrunning a consumer blocks).
        pub fn init(cap: usize) Self {
            return Self{ .id = @chanMake(if (cap == 0) @as(i64, -1) else @as(i64, @intCast(cap))) };
        }

        /// Send `value`. Blocks the current fiber while a bounded channel is full;
        /// errors with `ChannelClosed` if the channel has been closed.
        pub fn send(self: *Self, value: T) !void {
            if (not @chanSend(self.id, value)) return error.ChannelClosed;
        }

        /// Receive the next value, or `null` once the channel is closed AND
        /// drained — the canonical `while (ch.recv()) |v| { ... }` terminator.
        pub fn recv(self: *Self) ?T {
            return @chanRecv(self.id);
        }

        /// Close the channel: no further sends are admitted, and a drained `recv`
        /// returns `null`.
        pub fn close(self: *Self) void {
            @chanClose(self.id);
        }

        /// The number of buffered values currently in the channel.
        pub fn len(self: *const Self) usize {
            return @chanLen(self.id);
        }
    };
}

// =========================================================================
//  atomic — lock-free primitives (correct under the cooperative model)
// =========================================================================

/// Lock-free atomics. Under the single-threaded cooperative VM an RMW cannot be
/// interleaved mid-operation, so every op is trivially atomic; the `Ordering`
/// argument is accepted (the cost model is honest) and is a no-op here, while
/// native codegen emits the real fences. Every operation names its ordering, so
/// there is never a hidden "sequentially consistent by default".
pub const atomic = struct {
    /// The memory-ordering enum, required on every atomic operation (spec §4.2).
    pub const Ordering = enum {
        /// No ordering beyond atomicity of this one op. Correct for tallies.
        monotonic,
        /// An acquiring load; pairs with `release`.
        acquire,
        /// A releasing store; pairs with `acquire`.
        release,
        /// Both acquire and release on one RMW.
        acq_rel,
        /// A single global total order; strongest and most expensive.
        seq_cst,
    };

    /// A typed atomic cell. `T` is an integer or bool. Ordering is accepted and
    /// ignored on the single-threaded VM (see the namespace doc).
    pub fn Value(comptime T: type) type {
        return struct {
            const Self = @This();
            /// The VM-side atomic-cell id.
            id: u32,

            /// Construct an atomic initialized to `v`.
            pub fn init(v: T) Self {
                return Self{ .id = @atomicMake(@as(i128, @intCast(v))) };
            }

            /// Atomically read the value.
            pub fn load(self: *const Self, order: Ordering) T {
                _ = order;
                return @as(T, @intCast(@atomicLoad(self.id)));
            }

            /// Atomically write `v`.
            pub fn store(self: *Self, v: T, order: Ordering) void {
                _ = order;
                @atomicStore(self.id, @as(i128, @intCast(v)));
            }

            /// Atomically add `delta`, returning the PREVIOUS value (spec §4.1).
            pub fn fetchAdd(self: *Self, delta: T, order: Ordering) T {
                _ = order;
                return @as(T, @intCast(@atomicFetchAdd(self.id, @as(i128, @intCast(delta)))));
            }

            /// Atomically store `v`, returning the previous value.
            pub fn swap(self: *Self, v: T, order: Ordering) T {
                _ = order;
                return @as(T, @intCast(@atomicSwap(self.id, @as(i128, @intCast(v)))));
            }

            /// Compare-and-swap: returns `null` on success, else the actual
            /// witnessed value to retry against (spec §4.3 lock-free idiom).
            pub fn cmpxchgStrong(self: *Self, expected: T, new: T, so: Ordering, fo: Ordering) ?T {
                _ = so;
                _ = fo;
                const w = @atomicCas(self.id, @as(i128, @intCast(expected)), @as(i128, @intCast(new)));
                if (w) |actual| {
                    return @as(T, @intCast(actual));
                } else {
                    return null;
                }
            }

            /// As `cmpxchgStrong`; the VM never fails spuriously, so the two
            /// coincide (a retry loop written against `Weak` is still correct).
            pub fn cmpxchgWeak(self: *Self, expected: T, new: T, so: Ordering, fo: Ordering) ?T {
                return self.cmpxchgStrong(expected, new, so, fo);
            }
        };
    }
};

// =========================================================================
//  event — the explicit async event-loop capability (§8)
// =========================================================================

/// The async event-loop namespace. A `Loop` is a capability built from the heap;
/// `loop.spawn(f, args)` returns a `Future` (a task under the hood) and
/// `future.await(loop, T)` drives it to completion and yields its value. Colorless
/// and keyword-free: `spawn`/`await` are ordinary method calls (spec §§7–8).
pub const event = struct {
    /// The event loop: drives spawned frames to completion. Built from `sys.heap`,
    /// passed explicitly, never ambient.
    pub const Loop = struct {
        const Self = @This();
        /// The allocator the loop was built over.
        alloc: Allocator,

        /// Construct an event loop over the heap capability.
        pub fn init(alloc: Allocator) Self {
            return Self{ .alloc = alloc };
        }

        /// Tear down the loop (a no-op for the fiber realization).
        pub fn deinit(self: *Self) void {
            _ = self;
        }

        /// Start `work(args...)` as a fiber and return a `Future`. Like
        /// `Executor.spawn`, this call is rewritten to `@schedSpawn` with `work`
        /// resolved to its function reference.
        pub fn spawn(self: *Self, work: anytype, args: anytype) Future {
            _ = self;
            return Future{ .id = @schedSpawn(work, args) };
        }

        /// Drive all in-flight frames to completion: drives the scheduler to
        /// quiescence (the same `@schedRun` drain as `Executor.waitIdle`), so every
        /// spawned frame — and any child frame it awaits — has finished before this
        /// returns.
        pub fn run(self: *Self) void {
            _ = self;
            @schedRun();
        }
    };

    /// A future / frame handle the caller owns. `await(loop, T)` drives it to
    /// completion and yields its `T` result.
    pub const Future = struct {
        const Self = @This();
        /// The VM-side fiber id.
        id: u32,

        /// Drive this frame to completion under `loop` and yield its `T` value.
        pub fn await(self: Self, loop: anytype, comptime T: type) T {
            _ = loop;
            return @schedAwait(self.id);
        }
    };
};

// =========================================================================
//  fs / os / time / net — the v0.23 OS-effect capabilities (spec §7.4)
// =========================================================================
//
// These are the real-effect surfaces reached through `*System`: `sys.fs`,
// `sys.os`, `sys.time`, `sys.net`. Every door method is a member call on the
// capability value (no ambient global), backed by Rust `std` on the VM and raw
// syscalls (where feasible) natively. The handle TYPES below (`File`/`Stat`/
// `TcpListener`/`TcpStream`/`Duration`/`Instant`) and ERROR SETS are the spec
// vocabulary; the door itself (`sys.fs.openRead(...)`, `sys.net.listen(...)`, …)
// is realized by the VM intrinsic floor. Tests use TEMP files + LOOPBACK only,
// are self-cleaning, and assert only inequalities for real time, so they stay
// deterministic and offline.

/// The error set a filesystem operation can fail with. Mapped from the host's
/// `io::ErrorKind` (NotFound → `FileNotFound`, PermissionDenied → `AccessDenied`,
/// …) by the VM, and constructed BY NAME so no enum wiring is needed.
pub const FsError = error{
    FileNotFound,
    AccessDenied,
    AlreadyExists,
    NotADirectory,
    IsADirectory,
    IoError,
    NoSpaceLeft,
};

/// The error set a network operation can fail with.
pub const NetError = error{
    ConnectionRefused,
    ConnectionReset,
    AddressInUse,
    WouldBlock,
    IoError,
};

/// The filesystem namespace: the `File`/`Dir` handle types and the `Stat` record.
/// The capability door is `sys.fs` (its methods `openRead`/`create`/`stat`/… are
/// the real effects); these types describe what the door hands back.
pub const fs = struct {
    /// What `stat`/`File.stat` report about a path: its byte size and whether it
    /// is a directory. (A small, honest record — not the full `struct stat`.)
    pub const Stat = struct {
        /// The file size in bytes.
        size: u64,
        /// `true` for a directory.
        is_dir: bool,
    };

    /// An open file handle, minted by `sys.fs.openRead`/`create`/`openReadWrite`.
    /// `handle` is the VM/native fd id; the methods are the real read/write/stat/
    /// close effects (each demuxed to the file by receiver kind in the VM).
    pub const File = struct {
        const Self = @This();
        /// The VM/native open-file handle id.
        handle: u32,

        /// Read up to `buf.len` bytes into `buf`, returning the count read (0 at EOF).
        pub fn read(self: *Self, buf: []u8) FsError!usize {
            return @fsRead(self.handle, buf);
        }

        /// Write all of `bytes`, returning the count written.
        pub fn write(self: *Self, bytes: []const u8) FsError!usize {
            return @fsWrite(self.handle, bytes);
        }

        /// Stat this open file (its current size / kind).
        pub fn stat(self: *Self) FsError!Stat {
            return @fsFstat(self.handle);
        }

        /// Close the file (also closed automatically when its slot is reused).
        pub fn close(self: *Self) void {
            @fsClose(self.handle);
        }
    };
};

/// The process namespace: command-line arguments, environment lookup, the process
/// id, and exit. The capability door is `sys.os` (and the env reader `sys.env`).
pub const os = struct {
    /// The number of forwarded program arguments (`k2c run prog -- a b` → 2).
    pub fn argCount(sys: *System) usize {
        _ = sys;
        return @osArgCount();
    }
};

/// The time namespace: the real wall/monotonic clocks (reached through `sys.time`),
/// plus the pure-k2 `Duration`/`Instant` value types built over them. The
/// DETERMINISTIC clock (`sys.clock`) stays the default for reproducible tests; the
/// real clock is opt-in per call here, and `Instant`/`Duration` work over either.
pub const time = struct {
    /// Nanoseconds in a millisecond / second (the conversion constants).
    pub const ns_per_ms: u64 = 1_000_000;
    pub const ns_per_s: u64 = 1_000_000_000;

    /// A span of time, in nanoseconds. A plain value — no capability needed to do
    /// arithmetic on a measured duration.
    pub const Duration = struct {
        const Self = @This();
        /// The span length in nanoseconds.
        ns: u64,

        /// Build a `Duration` of `ms` milliseconds.
        pub fn fromMillis(ms: u64) Self {
            return Self{ .ns = ms * ns_per_ms };
        }

        /// This span in whole milliseconds (truncating).
        pub fn asMillis(self: Self) u64 {
            return self.ns / ns_per_ms;
        }

        /// This span in nanoseconds.
        pub fn asNanos(self: Self) u64 {
            return self.ns;
        }
    };

    /// A captured point on the monotonic clock, in nanoseconds. Build one from a
    /// monotonic reading — `Instant.fromNanos(sys.time.monotonicReal())` for the
    /// REAL clock, or `Instant.fromNanos(sys.clock.monotonicNanos())` for the
    /// DETERMINISTIC test clock — and measure a `Duration` with `elapsedSince`,
    /// passing a later reading from the same clock. Because the monotonic clock is
    /// non-decreasing, the elapsed span is always well-defined.
    ///
    /// `Instant` deliberately takes the nanosecond READING (a `u64`), not the
    /// capability: that keeps it a plain, non-generic value type usable with EITHER
    /// clock, and keeps the authority to read the clock at the call site where
    /// `sys.time`/`sys.clock` is visible — exactly the capability discipline.
    pub const Instant = struct {
        const Self = @This();
        /// The captured monotonic reading, in nanoseconds.
        ns: u64,

        /// Capture an instant from a monotonic nanosecond reading.
        pub fn fromNanos(ns: u64) Self {
            return Self{ .ns = ns };
        }

        /// The `Duration` elapsed from `self` to `now_ns` (a later reading of the
        /// same monotonic clock).
        pub fn elapsedSince(self: Self, now_ns: u64) Duration {
            return Duration{ .ns = now_ns - self.ns };
        }
    };
};

/// The network namespace: the `TcpListener`/`TcpStream` handle types. The
/// capability door is `sys.net` (`listen`/`connect`); these types describe what it
/// hands back. Loopback only in tests (`127.0.0.1`, ephemeral port), self-cleaning.
pub const net = struct {
    /// A bound TCP listener (minted by `sys.net.listen(port)`; port 0 = ephemeral).
    pub const TcpListener = struct {
        const Self = @This();
        /// The VM/native listener handle id.
        handle: u32,

        /// Accept the next incoming connection, yielding a connected stream.
        pub fn accept(self: *Self) NetError!TcpStream {
            return @netAccept(self.handle);
        }

        /// The bound local port (so an ephemeral listener's port is readable).
        pub fn localPort(self: *Self) u16 {
            return @netLocalPort(self.handle);
        }

        /// Close the listener.
        pub fn close(self: *Self) void {
            @netClose(self.handle);
        }
    };

    /// A connected TCP stream (minted by `listener.accept()` / `sys.net.connect`).
    pub const TcpStream = struct {
        const Self = @This();
        /// The VM/native stream handle id.
        handle: u32,

        /// Send all of `bytes`, returning the count sent.
        pub fn send(self: *Self, bytes: []const u8) NetError!usize {
            return @netSend(self.handle, bytes);
        }

        /// Receive up to `buf.len` bytes into `buf`, returning the count read.
        pub fn recv(self: *Self, buf: []u8) NetError!usize {
            return @netRecv(self.handle, buf);
        }

        /// Close the stream.
        pub fn close(self: *Self) void {
            @netClose(self.handle);
        }
    };
};
